---
import "../styles/global.css";
import { getSession } from "../lib/auth";
import { db } from "../lib/db";
import {
	getAssignmentForHunter,
	getTargetClues,
	computeScore,
} from "../lib/hunt";

const session = getSession(Astro.cookies);
if (!session) return Astro.redirect("/");

const { rows } = await db.execute({
	sql: "SELECT onboarding_status FROM users WHERE slack_id = ?",
	args: [session.slack_id],
});
const status = rows[0]?.onboarding_status as string | undefined;
if (status === "pending_submission" || status === "changes_requested") {
	return Astro.redirect("/onboard");
}
if (status !== "approved") return Astro.redirect("/");

const assignment = await getAssignmentForHunter(session.slack_id);

const clues = assignment ? await getTargetClues(assignment.target_id) : [];

// What a find would be worth if submitted right now - drops purely with time.
let potentialScore: number | null = null;
if (assignment?.status === "active" && assignment.started_at) {
	const elapsed = Math.floor(Date.now() / 1000) - assignment.started_at;
	potentialScore = computeScore(elapsed);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" />
    <title>pispy - hunt</title>
  </head>
  <body class="bg-[#111] font-sans text-[#ccc]">
    <div class="mx-auto max-w-[560px] px-6 pt-10 pb-16">
      <nav class="mb-12 flex gap-6 border-b border-[#1e1e1e] pb-4 text-[0.85rem]">
        <a href="/" class="text-[#888] no-underline hover:text-[#ccc]">home</a>
        <a href="/leaderboard" class="text-[#888] no-underline hover:text-[#ccc]">leaderboard</a>
        <a href="/api/auth/logout" class="ml-auto text-[#888] no-underline hover:text-[#ccc]">log out</a>
      </nav>

      {
        !assignment ? (
          <div class="py-12 text-center">
            <p class="mb-[0.6rem] text-[1.2rem] text-[#ddd]">No target assigned yet.</p>
          </div>
        ) : assignment.status === "assigned" ? (
          <div class="py-12 text-center">
            <p class="mb-[0.6rem] text-[1.2rem] text-[#ddd]">You have a target.</p>
            <form action="/api/hunt/start" method="POST">
              <button
                type="submit"
                class="cursor-pointer rounded border border-[#3a5a7a] bg-[#2a3a4a] px-8 py-[0.6rem] text-[0.95rem] text-[#cfe2f0] transition-colors hover:border-[#4a6a8a] hover:bg-[#34485c]"
              >
                Start hunt
              </button>
            </form>
          </div>
        ) : assignment.status === "submitted" ? (
          <div>
            <header class="mb-8">
              <h1 class="mb-2 text-[1.2rem] font-semibold text-[#ddd]">Submitted for review</h1>
              <p class="text-[0.9rem] leading-[1.5] text-[#888]">
                An admin is confirming your photo. If it checks out, you'll earn{" "}
                {assignment.score} points.
              </p>
            </header>
            <img
              src={`/api/captures/${assignment.id}`}
              alt="your submission"
              class="block w-full rounded-md border border-[#222]"
            />
          </div>
        ) : assignment.status === "completed" ? (
          <div>
            <header class="mb-8">
              <h1 class="mb-2 text-[1.2rem] font-semibold text-[#ddd]">Target found</h1>
              <p class="text-[0.9rem] leading-[1.5] text-[#888]">
                Confirmed. You earned {assignment.score} points.{" "}
                <a href="/leaderboard" class="text-[#6a9aba]">See the leaderboard.</a>
              </p>
            </header>
            <img
              src={`/api/captures/${assignment.id}`}
              alt="your submission"
              class="block w-full rounded-md border border-[#222]"
            />
          </div>
        ) : (
          <div>
            <header class="mb-8">
              <h1 class="mb-2 text-[1.2rem] font-semibold text-[#ddd]">Your target</h1>
              <p class="text-[0.9rem] leading-[1.5] text-[#888]">
                Here's everything we know about them. Find them fast. <br>
                score goes down if you take too long :(
                enjoy the clues!
              </p>
            </header>

            {assignment.review_note && (
              <div class="mb-6 rounded-r border-l-2 border-[#8a4a4a] bg-[#1a1414] px-4 py-3">
                <span class="mb-[0.3rem] block text-[0.65rem] uppercase tracking-[0.1em] text-[#aa6a6a]">submission rejected</span>
                <p class="text-[0.88rem] text-[#ccbbbb]">{assignment.review_note}</p>
              </div>
            )}

            {clues.length === 0 ? (
              <p class="text-[0.9rem] text-[#666]">No clues available for this target. (this might have been a terrible glitch)</p>
            ) : (
              <div class="flex flex-col">
                {clues.map((c, i) => (
                  <div class="flex items-baseline gap-4 border-t border-[#1a1a1a] py-4">
                    <span class="font-mono text-[0.7rem] text-[#666]">
                      {String(i + 1).padStart(2, "0")}
                    </span>
                    <div>
                      <span class="mb-[0.3rem] block text-[0.75rem] text-[#888]">{c.prompt}</span>
                      <span class="mb-[0.35rem] inline-block border border-[#292929] px-[0.35rem] py-[0.08rem] text-[0.62rem] uppercase tracking-[0.06em] text-[#666]">
                        {c.difficulty}
                      </span>
                      <span class="block text-base text-[#ddd]">{c.answer}</span>
                    </div>
                  </div>
                ))}
              </div>
            )}

            {potentialScore !== null && (
              <div class="mt-6 flex justify-end border-t border-[#1e1e1e] pt-4 text-[0.78rem] text-[#888]">
                <span>worth ~{potentialScore} pts now</span>
              </div>
            )}

            <div class="mt-10 border-t border-[#1e1e1e] pt-6">
              <p class="mb-[0.3rem] text-base text-[#ddd]">Found them?</p>
              <form
                action="/api/hunt/submit"
                method="POST"
                enctype="multipart/form-data"
                id="submit-form"
              >
                <div id="capture-field">
                  <div class="mb-[0.6rem] flex aspect-[4/3] w-full items-center justify-center overflow-hidden rounded border border-[#222] bg-[#161616]">
                    <img
                      id="capture-preview"
                      class="h-full w-full object-cover"
                      hidden
                      alt=""
                    />
                    <video
                      id="capture-video"
                      class="h-full w-full object-cover"
                      autoplay
                      playsinline
                      muted
                      hidden
                    />
                    <canvas id="capture-canvas" hidden />
                  </div>
                  <div class="mb-5 flex flex-wrap items-center gap-[0.6rem]">
                    <label class="cursor-pointer rounded border border-[#333] bg-none px-[0.8rem] py-[0.35rem] text-[0.82rem] text-[#999] transition-colors hover:border-[#555] hover:text-[#ccc]">
                      upload file
                      <input
                        type="file"
                        id="capture-file"
                        accept="image/*"
                        hidden
                      />
                    </label>
                    <span class="text-[0.78rem] text-[#666]">or</span>
                    <button
                      type="button"
                      class="cursor-pointer rounded border border-[#333] bg-none px-[0.8rem] py-[0.35rem] text-[0.82rem] text-[#999] transition-colors hover:border-[#555] hover:text-[#ccc]"
                      id="capture-camera-open"
                    >
                      use camera
                    </button>
                    <button
                      type="button"
                      class="cursor-pointer rounded border border-[#333] bg-none px-[0.8rem] py-[0.35rem] text-[0.82rem] text-[#999] transition-colors hover:border-[#555] hover:text-[#ccc]"
                      id="capture-snap"
                      hidden
                    >
                      snap
                    </button>
                    <button
                      type="button"
                      class="cursor-pointer border-none bg-none py-[0.35rem] text-[0.82rem] text-[#777] hover:text-[#aaa]"
                      id="capture-retake"
                      hidden
                    >
                      retake
                    </button>
                  </div>
                  <input
                    type="hidden"
                    name="capture_photo_data"
                    id="capture-data"
                  />
                  <input
                    type="file"
                    name="capture_photo_file"
                    id="capture-file-fallback"
                    accept="image/*"
                    class="hidden"
                  />
                </div>
                <button
                  type="submit"
                  class="cursor-pointer rounded border border-[#3a5a7a] bg-[#2a3a4a] px-8 py-[0.6rem] text-[0.95rem] text-[#cfe2f0] transition-colors hover:border-[#4a6a8a] hover:bg-[#34485c]"
                >
                  Submit photo
                </button>
              </form>
            </div>
          </div>
        )
      }
    </div>

    <script>
      function setupPhotoField(id: string) {
        const fileInput = document.getElementById(
          `${id}-file`,
        ) as HTMLInputElement | null;
        if (!fileInput) return;
        const fileFallback = document.getElementById(
          `${id}-file-fallback`,
        ) as HTMLInputElement;
        const dataInput = document.getElementById(
          `${id}-data`,
        ) as HTMLInputElement;
        const preview = document.getElementById(
          `${id}-preview`,
        ) as HTMLImageElement;
        const video = document.getElementById(
          `${id}-video`,
        ) as HTMLVideoElement;
        const canvas = document.getElementById(
          `${id}-canvas`,
        ) as HTMLCanvasElement;
        const cameraOpen = document.getElementById(
          `${id}-camera-open`,
        ) as HTMLButtonElement;
        const snapBtn = document.getElementById(
          `${id}-snap`,
        ) as HTMLButtonElement;
        const retakeBtn = document.getElementById(
          `${id}-retake`,
        ) as HTMLButtonElement;

        let stream: MediaStream | null = null;

        function showPreview(dataUrl: string) {
          preview.src = dataUrl;
          preview.hidden = false;
          video.hidden = true;
          snapBtn.hidden = true;
          retakeBtn.hidden = false;
          cameraOpen.hidden = true;
          fileFallback.disabled = true;
        }

        function stopStream() {
          stream?.getTracks().forEach((t) => t.stop());
          stream = null;
          video.hidden = true;
        }

        fileInput.addEventListener("change", () => {
          const file = fileInput.files?.[0];
          if (!file) return;
          const reader = new FileReader();
          reader.onload = (e) => {
            const result = e.target?.result as string;
            dataInput.value = result;
            fileFallback.disabled = true;
            showPreview(result);
            stopStream();
          };
          reader.readAsDataURL(file);
        });

        cameraOpen.addEventListener("click", async () => {
          try {
            stream = await navigator.mediaDevices.getUserMedia({
              video: { facingMode: "environment" },
            });
            video.srcObject = stream;
            video.hidden = false;
            preview.hidden = true;
            snapBtn.hidden = false;
            cameraOpen.hidden = true;
          } catch {
            alert("Could not access camera. Please upload a file instead.");
          }
        });

        snapBtn.addEventListener("click", () => {
          canvas.width = video.videoWidth;
          canvas.height = video.videoHeight;
          canvas.getContext("2d")!.drawImage(video, 0, 0);
          const dataUrl = canvas.toDataURL("image/jpeg", 0.85);
          dataInput.value = dataUrl;
          fileFallback.disabled = true;
          showPreview(dataUrl);
          stopStream();
        });

        retakeBtn.addEventListener("click", () => {
          dataInput.value = "";
          preview.hidden = true;
          retakeBtn.hidden = true;
          cameraOpen.hidden = false;
          fileFallback.disabled = false;
        });
      }

      setupPhotoField("capture");

      document.querySelectorAll(".fallback-file").forEach((el) => {
        (el as HTMLElement).style.display = "none";
      });
    </script>
  </body>
</html>
