---
import '../../styles/global.css';
import { db } from '../../lib/db';

const { rows: approved } = await db.execute(
  `SELECT slack_id, display_name FROM users WHERE onboarding_status = 'approved' ORDER BY display_name`
);

// Assignments joined with hunter/target names and how many clues the target has.
const { rows: assignments } = await db.execute(`
  SELECT
    a.id, a.status, a.started_at,
    h.display_name AS hunter_name,
    t.display_name AS target_name,
    ((SELECT COUNT(*) FROM user_clues uc WHERE uc.slack_id = a.target_id) +
     (SELECT COUNT(*) FROM custom_clues cc WHERE cc.slack_id = a.target_id)) AS total
  FROM assignments a
  JOIN users h ON h.slack_id = a.hunter_id
  JOIN users t ON t.slack_id = a.target_id
  ORDER BY a.created_at DESC
`);

const statusLabel: Record<string, string> = {
  assigned: 'not started',
  active: 'hunting',
  submitted: 'needs review',
  completed: 'found',
};

const statusClass: Record<string, string> = {
  assigned: 'text-[#b3b35a]',
  active: 'text-[#6a9aba]',
  submitted: 'text-[#c08a4a]',
  completed: 'text-[#6a9a6a]',
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>pispy — assignments</title>
  </head>
  <body class="bg-[#111] font-sans text-[#ccc]">
    <div class="mx-auto max-w-[760px] px-6 pt-10 pb-16">
      <nav class="mb-10 flex gap-6 border-b border-[#1e1e1e] pb-4 text-[0.85rem]">
        <a href="/admin" class="text-[#888] no-underline hover:text-[#ccc]">review</a>
        <a href="/admin/users" class="text-[#888] no-underline hover:text-[#ccc]">users</a>
        <a href="/admin/fields" class="text-[#888] no-underline hover:text-[#ccc]">fields</a>
        <a href="/admin/assignments" class="text-[#888] no-underline hover:text-[#ccc]">assignments</a>
        <a href="/leaderboard" class="text-[#888] no-underline hover:text-[#ccc]">leaderboard</a>
        <a href="/api/auth/logout" class="ml-auto text-[#888] no-underline hover:text-[#ccc]">leave</a>
      </nav>

      <h1 class="mb-[0.4rem] text-[1.05rem] font-semibold text-[#ddd]">assignments</h1>
      <p class="mb-7 text-[0.82rem] text-[#888]">Assign each hunter a target. Hunters see all the target's clues and submit a photo when they find them.</p>

      {assignments.length === 0 ? (
        <p class="text-[0.9rem] text-[#666]">no assignments yet</p>
      ) : (
        <table class="mb-8 w-full border-collapse [&_td]:border-t [&_td]:border-[#1a1a1a] [&_td]:py-[0.65rem] [&_td]:align-middle [&_td]:text-[0.875rem] [&_th]:pb-2 [&_th]:text-left [&_th]:text-[0.65rem] [&_th]:font-normal [&_th]:uppercase [&_th]:tracking-[0.1em] [&_th]:text-[#444]">
          <thead>
            <tr><th>hunter</th><th>target</th><th>status</th><th>clues</th><th></th></tr>
          </thead>
          <tbody>
            {assignments.map(a => (
              <tr>
                <td>{a.hunter_name as string}</td>
                <td>{a.target_name as string}</td>
                <td class={statusClass[a.status as string] ?? ''}>{statusLabel[a.status as string] ?? a.status as string}</td>
                <td class="font-mono !text-[0.75rem] text-[#777]">{a.total as number}</td>
                <td class="flex items-center gap-5">
                  <a href={`/admin/assignment/${a.id}`} class="text-[#999] no-underline hover:text-[#ccc]">manage →</a>
                  <form action="/api/admin/assignments" method="POST">
                    <input type="hidden" name="action" value="unassign" />
                    <input type="hidden" name="id" value={a.id as number} />
                    <button type="submit" class="cursor-pointer border-none bg-none p-0 font-sans text-[0.8rem] text-[#aa6a6a] hover:text-[#ca8a8a]">unassign</button>
                  </form>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}

      <div class="mt-6 border-t border-[#1e1e1e] pt-6">
        <p class="mb-3 text-[0.65rem] uppercase tracking-[0.1em] text-[#777]">new assignment</p>
        {approved.length < 2 ? (
          <p class="text-[0.9rem] text-[#666]">need at least two approved users to make an assignment.</p>
        ) : (
          <form action="/api/admin/assignments" method="POST" class="flex flex-wrap items-end gap-4">
            <input type="hidden" name="action" value="assign" />
            <label class="flex flex-col gap-[0.35rem]">
              <span class="text-[0.72rem] text-[#999]">hunter</span>
              <select name="hunter_id" required class="min-w-[180px] rounded border border-[#2a2a2a] bg-[#161616] px-[0.6rem] py-[0.4rem] font-sans text-[0.85rem] text-[#ccc] outline-none focus:border-[#555]">
                <option value="" disabled selected>choose…</option>
                {approved.map(u => (
                  <option value={u.slack_id as string}>{u.display_name as string}</option>
                ))}
              </select>
            </label>
            <label class="flex flex-col gap-[0.35rem]">
              <span class="text-[0.72rem] text-[#999]">target</span>
              <select name="target_id" required class="min-w-[180px] rounded border border-[#2a2a2a] bg-[#161616] px-[0.6rem] py-[0.4rem] font-sans text-[0.85rem] text-[#ccc] outline-none focus:border-[#555]">
                <option value="" disabled selected>choose…</option>
                {approved.map(u => (
                  <option value={u.slack_id as string}>{u.display_name as string}</option>
                ))}
              </select>
            </label>
            <button type="submit" class="cursor-pointer whitespace-nowrap rounded border border-[#444] bg-none px-5 py-[0.4rem] font-sans text-[0.85rem] text-[#ccc] transition-colors hover:border-[#888] hover:text-white">assign</button>
          </form>
        )}
      </div>
    </div>
  </body>
</html>
