---
import '../../../styles/global.css';
import { db } from '../../../lib/db';

const { slack_id } = Astro.params;

const { rows } = await db.execute({
  sql: 'SELECT display_name, avatar_url, onboarding_status, review_note FROM users WHERE slack_id = ?',
  args: [slack_id!],
});
if (!rows[0]) return Astro.redirect('/admin/users');
const user = rows[0];

// Every clue field, with the user's answer (if any) so admins can edit them all.
const { rows: fields } = await db.execute({
  sql: `SELECT cf.id, cf.prompt, uc.answer
        FROM clue_fields cf
        LEFT JOIN user_clues uc ON uc.field_id = cf.id AND uc.slack_id = ?
        ORDER BY cf.field_order, cf.id`,
  args: [slack_id!],
});
const { rows: customClues } = await db.execute({
  sql: 'SELECT id, clue, difficulty FROM custom_clues WHERE slack_id = ? ORDER BY id',
  args: [slack_id!],
});

// Cache-bust the photo URLs so a fresh upload shows immediately.
const cb = Date.now();
const statuses = ['pending_submission', 'pending_review', 'approved', 'changes_requested'];
const currentStatus = user.onboarding_status as string;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>pispy — inspect {user.display_name as string}</title>
  </head>
  <body class="bg-[#111] font-sans text-[#ccc]">
    <div class="mx-auto max-w-[640px] px-6 pt-10 pb-16">
      <nav class="mb-10 flex gap-6 border-b border-[#1e1e1e] pb-4 text-[0.8rem]">
        <a href="/admin/users" class="text-[#666] no-underline hover:text-[#ccc]">← users</a>
        <a href="/admin/assignments" class="text-[#666] no-underline hover:text-[#ccc]">assignments</a>
        <a href="/api/auth/logout" class="ml-auto text-[#666] no-underline hover:text-[#ccc]">leave</a>
      </nav>

      <header class="mb-10 flex items-center gap-4">
        {user.avatar_url && <img src={user.avatar_url as string} alt="" class="h-12 w-12 rounded-full object-cover grayscale-[20%]" />}
        <div>
          <h1 class="mb-[0.15rem] text-[1.1rem] font-normal text-[#ddd]">{user.display_name as string}</h1>
          <p class="font-mono text-[0.75rem] text-[#555]">{slack_id}</p>
        </div>
      </header>

      <!-- profile / status override -->
      <section class="mb-10 border-b border-[#1a1a1a] pb-10 last:border-b-0">
        <p class="mb-4 text-[0.65rem] uppercase tracking-[0.1em] text-[#444]">profile</p>
        <form action="/api/admin/override" method="POST" class="flex flex-col items-start gap-4">
          <input type="hidden" name="action" value="update_profile" />
          <input type="hidden" name="slack_id" value={slack_id} />
          <label class="flex w-full flex-col gap-[0.35rem]">
            <span class="text-[0.7rem] text-[#666]">display name</span>
            <input type="text" name="display_name" value={user.display_name as string} required class="w-full border border-[#2a2a2a] bg-[#161616] px-[0.65rem] py-2 font-sans text-[0.9rem] text-[#ccc] outline-none transition-colors focus:border-[#555]" />
          </label>
          <label class="flex w-full flex-col gap-[0.35rem]">
            <span class="text-[0.7rem] text-[#666]">onboarding status</span>
            <select name="onboarding_status" class="w-full border border-[#2a2a2a] bg-[#161616] px-[0.65rem] py-2 font-sans text-[0.9rem] text-[#ccc] outline-none transition-colors focus:border-[#555]">
              {statuses.map(s => (
                <option value={s} selected={s === currentStatus}>{s.replace(/_/g, ' ')}</option>
              ))}
            </select>
          </label>
          <label class="flex w-full flex-col gap-[0.35rem]">
            <span class="text-[0.7rem] text-[#666]">review note (shown to user on changes requested)</span>
            <textarea name="review_note" rows="2" class="w-full resize-y border border-[#2a2a2a] bg-[#161616] px-[0.65rem] py-2 font-sans text-[0.9rem] text-[#ccc] outline-none transition-colors focus:border-[#555]">{(user.review_note as string) ?? ''}</textarea>
          </label>
          <button type="submit" class="cursor-pointer border border-[#333] bg-none px-5 py-[0.45rem] font-sans text-[0.85rem] text-[#888] transition-colors hover:border-[#555] hover:text-[#ccc]">save profile</button>
        </form>
      </section>

      <section class="mb-10 border-b border-[#1a1a1a] pb-10 last:border-b-0">
        <p class="mb-4 text-[0.65rem] uppercase tracking-[0.1em] text-[#444]">custom clues</p>
        {customClues.length === 0 ? <p class="text-[0.9rem] text-[#555]">no custom clues</p> : (
          <form action="/api/admin/override" method="POST" class="flex flex-col items-start gap-4">
            <input type="hidden" name="action" value="update_custom_clues" />
            <input type="hidden" name="slack_id" value={slack_id} />
            {customClues.map(c => (
              <div class="grid w-full grid-cols-[1fr_auto_auto] items-center gap-[0.6rem]">
                <input type="text" name={`custom_clue_${c.id}`} value={c.clue as string} class="w-full border border-[#2a2a2a] bg-[#161616] px-[0.65rem] py-2 font-sans text-[0.9rem] text-[#ccc] outline-none transition-colors focus:border-[#555]" />
                <select name={`custom_difficulty_${c.id}`} class="w-full border border-[#2a2a2a] bg-[#161616] px-[0.65rem] py-2 font-sans text-[0.9rem] text-[#ccc] outline-none transition-colors focus:border-[#555]">{['hard', 'medium', 'easy'].map(level => <option value={level} selected={c.difficulty === level}>{level}</option>)}</select>
                <label class="text-[0.75rem] text-[#755]"><input type="checkbox" name={`delete_custom_${c.id}`} /> remove</label>
              </div>
            ))}
            <button type="submit" class="cursor-pointer border border-[#333] bg-none px-5 py-[0.45rem] font-sans text-[0.85rem] text-[#888] transition-colors hover:border-[#555] hover:text-[#ccc]">save custom clues</button>
          </form>
        )}
      </section>

      <!-- photo override -->
      <section class="mb-10 border-b border-[#1a1a1a] pb-10 last:border-b-0">
        <p class="mb-4 text-[0.65rem] uppercase tracking-[0.1em] text-[#444]">badge &amp; face</p>
        <div class="mb-5 grid grid-cols-2 gap-4">
          <div>
            <p class="mb-[0.4rem] text-[0.65rem] uppercase tracking-[0.1em] text-[#555]">badge</p>
            <img src={`/api/photos/${slack_id}/badge?cb=${cb}`} alt="badge photo" class="block aspect-[4/3] w-full border border-[#222] bg-[#161616] object-cover" />
          </div>
          <div>
            <p class="mb-[0.4rem] text-[0.65rem] uppercase tracking-[0.1em] text-[#555]">face</p>
            <img src={`/api/photos/${slack_id}/face?cb=${cb}`} alt="face photo" class="block aspect-[4/3] w-full border border-[#222] bg-[#161616] object-cover" />
          </div>
        </div>
        <form action="/api/admin/override" method="POST" enctype="multipart/form-data" class="flex flex-col items-start gap-4">
          <input type="hidden" name="action" value="update_photos" />
          <input type="hidden" name="slack_id" value={slack_id} />
          <label class="flex w-full flex-col gap-[0.35rem]">
            <span class="text-[0.7rem] text-[#666]">replace badge photo</span>
            <input type="file" name="badge_photo_file" accept="image/*" class="font-mono text-[0.75rem] text-[#888]" />
          </label>
          <label class="flex w-full flex-col gap-[0.35rem]">
            <span class="text-[0.7rem] text-[#666]">replace face photo</span>
            <input type="file" name="face_photo_file" accept="image/*" class="font-mono text-[0.75rem] text-[#888]" />
          </label>
          <button type="submit" class="cursor-pointer border border-[#333] bg-none px-5 py-[0.45rem] font-sans text-[0.85rem] text-[#888] transition-colors hover:border-[#555] hover:text-[#ccc]">save photos</button>
        </form>
      </section>

      <!-- clue answers override -->
      <section class="mb-10 border-b border-[#1a1a1a] pb-10 last:border-b-0">
        <p class="mb-4 text-[0.65rem] uppercase tracking-[0.1em] text-[#444]">clue answers</p>
        {fields.length === 0 ? (
          <p class="text-[0.9rem] text-[#555]">no clue fields defined. add them under <a href="/admin/fields" class="text-[#888]">fields</a>.</p>
        ) : (
          <form action="/api/admin/override" method="POST" class="flex flex-col items-start gap-4">
            <input type="hidden" name="action" value="update_clues" />
            <input type="hidden" name="slack_id" value={slack_id} />
            {fields.map(f => (
              <label class="flex w-full flex-col gap-[0.35rem]">
                <span class="text-[0.7rem] text-[#666]">{f.prompt as string}</span>
                <input
                  type="text"
                  name={`clue_${f.id}`}
                  value={(f.answer as string) ?? ''}
                  autocomplete="off"
                  placeholder="(empty — clearing removes this clue)"
                  class="w-full border border-[#2a2a2a] bg-[#161616] px-[0.65rem] py-2 font-sans text-[0.9rem] text-[#ccc] outline-none transition-colors focus:border-[#555]"
                />
              </label>
            ))}
            <button type="submit" class="cursor-pointer border border-[#333] bg-none px-5 py-[0.45rem] font-sans text-[0.85rem] text-[#888] transition-colors hover:border-[#555] hover:text-[#ccc]">save clues</button>
          </form>
        )}
      </section>
    </div>
  </body>
</html>
