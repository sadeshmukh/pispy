---
import { db } from '../../../lib/db';

const { slack_id } = Astro.params;

const { rows } = await db.execute({
  sql: 'SELECT display_name, avatar_url, onboarding_status, review_note FROM users WHERE slack_id = ?',
  args: [slack_id!],
});
if (!rows[0]) return Astro.redirect('/admin/users');
const user = rows[0];

// Every clue field, with the user's answer (if any) so admins can edit them all.
const { rows: fields } = await db.execute({
  sql: `SELECT cf.id, cf.prompt, uc.answer
        FROM clue_fields cf
        LEFT JOIN user_clues uc ON uc.field_id = cf.id AND uc.slack_id = ?
        ORDER BY cf.field_order, cf.id`,
  args: [slack_id!],
});
const { rows: customClues } = await db.execute({
  sql: 'SELECT id, clue, difficulty FROM custom_clues WHERE slack_id = ? ORDER BY id',
  args: [slack_id!],
});

// Cache-bust the photo URLs so a fresh upload shows immediately.
const cb = Date.now();
const statuses = ['pending_submission', 'pending_review', 'approved', 'changes_requested'];
const currentStatus = user.onboarding_status as string;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>pispy — inspect {user.display_name as string}</title>
  </head>
  <body>
    <div class="page">
      <nav>
        <a href="/admin/users">← users</a>
        <a href="/admin/assignments">assignments</a>
        <a href="/api/auth/logout" class="logout">leave</a>
      </nav>

      <header>
        {user.avatar_url && <img src={user.avatar_url as string} alt="" class="avatar" />}
        <div>
          <h1>{user.display_name as string}</h1>
          <p class="slack-id">{slack_id}</p>
        </div>
      </header>

      <!-- profile / status override -->
      <section>
        <p class="section-label">profile</p>
        <form action="/api/admin/override" method="POST" class="stack">
          <input type="hidden" name="action" value="update_profile" />
          <input type="hidden" name="slack_id" value={slack_id} />
          <label class="field">
            <span>display name</span>
            <input type="text" name="display_name" value={user.display_name as string} required />
          </label>
          <label class="field">
            <span>onboarding status</span>
            <select name="onboarding_status">
              {statuses.map(s => (
                <option value={s} selected={s === currentStatus}>{s.replace(/_/g, ' ')}</option>
              ))}
            </select>
          </label>
          <label class="field">
            <span>review note (shown to user on changes requested)</span>
            <textarea name="review_note" rows="2">{(user.review_note as string) ?? ''}</textarea>
          </label>
          <button type="submit" class="btn-save">save profile</button>
        </form>
      </section>

      <section>
        <p class="section-label">custom clues</p>
        {customClues.length === 0 ? <p class="empty">no custom clues</p> : (
          <form action="/api/admin/override" method="POST" class="stack">
            <input type="hidden" name="action" value="update_custom_clues" />
            <input type="hidden" name="slack_id" value={slack_id} />
            {customClues.map(c => (
              <div class="custom-row">
                <input type="text" name={`custom_clue_${c.id}`} value={c.clue as string} />
                <select name={`custom_difficulty_${c.id}`}>{['hard', 'medium', 'easy'].map(level => <option value={level} selected={c.difficulty === level}>{level}</option>)}</select>
                <label class="remove"><input type="checkbox" name={`delete_custom_${c.id}`} /> remove</label>
              </div>
            ))}
            <button type="submit" class="btn-save">save custom clues</button>
          </form>
        )}
      </section>

      <!-- photo override -->
      <section>
        <p class="section-label">badge &amp; face</p>
        <div class="photos">
          <div class="photo-wrap">
            <p class="photo-label">badge</p>
            <img src={`/api/photos/${slack_id}/badge?cb=${cb}`} alt="badge photo" class="photo" />
          </div>
          <div class="photo-wrap">
            <p class="photo-label">face</p>
            <img src={`/api/photos/${slack_id}/face?cb=${cb}`} alt="face photo" class="photo" />
          </div>
        </div>
        <form action="/api/admin/override" method="POST" enctype="multipart/form-data" class="stack">
          <input type="hidden" name="action" value="update_photos" />
          <input type="hidden" name="slack_id" value={slack_id} />
          <label class="field">
            <span>replace badge photo</span>
            <input type="file" name="badge_photo_file" accept="image/*" />
          </label>
          <label class="field">
            <span>replace face photo</span>
            <input type="file" name="face_photo_file" accept="image/*" />
          </label>
          <button type="submit" class="btn-save">save photos</button>
        </form>
      </section>

      <!-- clue answers override -->
      <section>
        <p class="section-label">clue answers</p>
        {fields.length === 0 ? (
          <p class="empty">no clue fields defined. add them under <a href="/admin/fields">fields</a>.</p>
        ) : (
          <form action="/api/admin/override" method="POST" class="stack">
            <input type="hidden" name="action" value="update_clues" />
            <input type="hidden" name="slack_id" value={slack_id} />
            {fields.map(f => (
              <label class="field">
                <span>{f.prompt as string}</span>
                <input
                  type="text"
                  name={`clue_${f.id}`}
                  value={(f.answer as string) ?? ''}
                  autocomplete="off"
                  placeholder="(empty — clearing removes this clue)"
                />
              </label>
            ))}
            <button type="submit" class="btn-save">save clues</button>
          </form>
        )}
      </section>
    </div>
  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { background: #111; color: #ccc; font-family: system-ui, -apple-system, sans-serif; }
  .page { max-width: 640px; margin: 0 auto; padding: 2.5rem 1.5rem 4rem; }
  nav {
    display: flex; gap: 1.5rem; margin-bottom: 2.5rem;
    padding-bottom: 1rem; border-bottom: 1px solid #1e1e1e;
    font-size: 0.8rem;
  }
  nav a { color: #666; text-decoration: none; }
  nav a:hover { color: #ccc; }
  nav .logout { margin-left: auto; }

  header { display: flex; align-items: center; gap: 1rem; margin-bottom: 2.5rem; }
  .avatar { width: 48px; height: 48px; border-radius: 50%; object-fit: cover; filter: grayscale(20%); }
  h1 { font-size: 1.1rem; font-weight: normal; color: #ddd; margin-bottom: 0.15rem; }
  .slack-id { font-size: 0.75rem; color: #555; font-family: ui-monospace, monospace; }

  section { margin-bottom: 2.5rem; padding-bottom: 2.5rem; border-bottom: 1px solid #1a1a1a; }
  section:last-child { border-bottom: none; }
  .section-label { font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: #444; margin-bottom: 1rem; }
  .empty { font-size: 0.9rem; color: #555; }
  .empty a { color: #888; }

  .stack { display: flex; flex-direction: column; gap: 1rem; align-items: flex-start; }
  .field { display: flex; flex-direction: column; gap: 0.35rem; width: 100%; }
  .field > span { font-size: 0.7rem; color: #666; }
  .custom-row { display: grid; grid-template-columns: 1fr auto auto; gap: 0.6rem; width: 100%; align-items: center; }
  .remove { color: #755; font-size: 0.75rem; }

  input[type="text"], select, textarea {
    background: #161616; border: 1px solid #2a2a2a; color: #ccc;
    font-family: system-ui, -apple-system, sans-serif; font-size: 0.9rem; padding: 0.5rem 0.65rem;
    outline: none; width: 100%; transition: border-color 0.2s;
  }
  input[type="text"], textarea { }
  input[type="text"]:focus, select:focus, textarea:focus { border-color: #555; }
  textarea { resize: vertical; }
  input[type="file"] { font-family: ui-monospace, monospace; font-size: 0.75rem; color: #888; }

  .photos { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.25rem; }
  .photo-label { font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: #555; margin-bottom: 0.4rem; }
  .photo {
    width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block;
    background: #161616; border: 1px solid #222;
  }

  .btn-save {
    background: none; border: 1px solid #333; color: #888;
    font-family: system-ui, -apple-system, sans-serif; font-size: 0.85rem;
    padding: 0.45rem 1.25rem; cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-save:hover { border-color: #555; color: #ccc; }
</style>
