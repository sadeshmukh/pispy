---
import "../../../styles/global.css";
import { db } from "../../../lib/db";
import { getAssignment, getTargetClues } from "../../../lib/hunt";

const id = parseInt(Astro.params.id!);
const assignment = id ? await getAssignment(id) : null;
if (!assignment) return Astro.redirect("/admin/assignments");

const { rows: names } = await db.execute({
	sql: `SELECT
          (SELECT display_name FROM users WHERE slack_id = ?) AS hunter_name,
          (SELECT display_name FROM users WHERE slack_id = ?) AS target_name`,
	args: [assignment.hunter_id, assignment.target_id],
});
const hunterName = names[0]?.hunter_name as string;
const targetName = names[0]?.target_name as string;

const clues = await getTargetClues(assignment.target_id);

const startedLabel = assignment.started_at
	? new Date(assignment.started_at * 1000).toLocaleString()
	: null;
const submittedLabel = assignment.submitted_at
	? new Date(assignment.submitted_at * 1000).toLocaleString()
	: null;
const cb = Date.now();

const statusClass: Record<string, string> = {
	assigned: "text-[#b3b35a]",
	active: "text-[#6a9aba]",
	submitted: "text-[#c08a4a]",
	completed: "text-[#6a9a6a]",
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>pispy - manage hunt</title>
  </head>
  <body class="bg-[#111] font-sans text-[#ccc]">
    <div class="mx-auto max-w-[700px] px-6 pt-10 pb-16">
      <nav class="mb-10 flex gap-6 border-b border-[#1e1e1e] pb-4 text-[0.85rem]">
        <a href="/admin/assignments" class="text-[#888] no-underline hover:text-[#ccc]">← assignments</a>
        <a href="/admin/users" class="text-[#888] no-underline hover:text-[#ccc]">users</a>
        <a href="/api/auth/logout" class="ml-auto text-[#888] no-underline hover:text-[#ccc]">leave</a>
      </nav>

      <header class="mb-7">
        <h1 class="mb-[0.4rem] text-[1.15rem] font-semibold text-[#ddd]">{hunterName} → {targetName}</h1>
        <p class="text-[0.8rem] text-[#888]">
          status: <span class={statusClass[assignment.status] ?? ''}>{assignment.status}</span>
          {startedLabel && <> · started {startedLabel}</>}
          · {clues.length} clues
          {assignment.score !== null && <> · {assignment.score} pts</>}
        </p>
      </header>

      {assignment.status === 'submitted' && (
        <section class="mb-8 rounded-md border border-[#2a2a2a] bg-[#161616] p-5">
          <p class="mb-4 text-[0.65rem] uppercase tracking-[0.1em] text-[#777]">submission to review</p>
          <p class="mb-4 text-[0.8rem] text-[#888]">
            submitted {submittedLabel} · worth {assignment.score} pts if confirmed
          </p>
          <div class="mb-5 grid grid-cols-[repeat(auto-fit,minmax(160px,1fr))] gap-4">
            <div>
              <p class="mb-[0.4rem] text-[0.65rem] uppercase tracking-[0.08em] text-[#888]">submitted photo</p>
              <img src={`/api/captures/${assignment.id}?cb=${cb}`} alt="submitted photo" class="block aspect-[4/3] w-full rounded border border-[#2a2a2a] bg-[#111] object-cover" />
            </div>
            <div>
              <p class="mb-[0.4rem] text-[0.65rem] uppercase tracking-[0.08em] text-[#888]">target - face</p>
              <img src={`/api/photos/${assignment.target_id}/face?cb=${cb}`} alt="target face" class="block aspect-[4/3] w-full rounded border border-[#2a2a2a] bg-[#111] object-cover" />
            </div>
            <div>
              <p class="mb-[0.4rem] text-[0.65rem] uppercase tracking-[0.08em] text-[#888]">target - badge</p>
              <img src={`/api/photos/${assignment.target_id}/badge?cb=${cb}`} alt="target badge" class="block aspect-[4/3] w-full rounded border border-[#2a2a2a] bg-[#111] object-cover" />
            </div>
          </div>
          <div class="flex flex-wrap items-start gap-5">
            <form action="/api/admin/assignments" method="POST">
              <input type="hidden" name="action" value="approve_capture" />
              <input type="hidden" name="id" value={assignment.id} />
              <button type="submit" class="cursor-pointer whitespace-nowrap rounded border border-[#3a5a3a] bg-none px-5 py-2 font-sans text-[0.85rem] text-[#7aaa7a] transition-colors hover:border-[#5a8a5a] hover:text-[#9aca9a]">confirm find - award {assignment.score} pts</button>
            </form>
            <form action="/api/admin/assignments" method="POST" class="flex min-w-[200px] flex-1 flex-col gap-2">
              <input type="hidden" name="action" value="reject_capture" />
              <input type="hidden" name="id" value={assignment.id} />
              <textarea name="note" placeholder="reason (optional)" rows="2" class="resize-y rounded border border-[#2a2a2a] bg-[#111] px-[0.65rem] py-2 font-sans text-[0.85rem] text-[#ccc] outline-none focus:border-[#555]"></textarea>
              <button type="submit" class="cursor-pointer rounded border border-[#5a3a3a] bg-none px-4 py-[0.45rem] font-sans text-[0.85rem] text-[#aa6a6a] transition-colors hover:border-[#8a4a4a] hover:text-[#ca8a8a]">reject</button>
            </form>
          </div>
        </section>
      )}

      {assignment.status === 'completed' && (
        <section class="mb-8 rounded-md border border-[#2a2a2a] bg-[#161616] p-5">
          <p class="mb-4 text-[0.65rem] uppercase tracking-[0.1em] text-[#777]">confirmed find</p>
          <p class="mb-4 text-[0.8rem] text-[#888]">{assignment.score} pts awarded · submitted {submittedLabel}</p>
          <div class="mb-5 grid grid-cols-[repeat(auto-fit,minmax(160px,1fr))] gap-4">
            <div>
              <p class="mb-[0.4rem] text-[0.65rem] uppercase tracking-[0.08em] text-[#888]">submitted photo</p>
              <img src={`/api/captures/${assignment.id}?cb=${cb}`} alt="submitted photo" class="block aspect-[4/3] w-full rounded border border-[#2a2a2a] bg-[#111] object-cover" />
            </div>
            <div>
              <p class="mb-[0.4rem] text-[0.65rem] uppercase tracking-[0.08em] text-[#888]">target - face</p>
              <img src={`/api/photos/${assignment.target_id}/face?cb=${cb}`} alt="target face" class="block aspect-[4/3] w-full rounded border border-[#2a2a2a] bg-[#111] object-cover" />
            </div>
          </div>
        </section>
      )}

      {assignment.status === 'assigned' && (
        <form action="/api/admin/assignments" method="POST" class="mb-7 flex items-center gap-4">
          <input type="hidden" name="action" value="start" />
          <input type="hidden" name="id" value={assignment.id} />
          <button type="submit" class="cursor-pointer rounded border border-[#444] bg-none px-5 py-[0.45rem] font-sans text-[0.85rem] text-[#ccc] transition-colors hover:border-[#888] hover:text-white">force start hunt</button>
          <span class="text-[0.78rem] text-[#777]">normally the hunter starts this themselves.</span>
        </form>
      )}

      <p class="mb-4 text-[0.65rem] uppercase tracking-[0.1em] text-[#777]">clues the hunter sees</p>
      {clues.length === 0 ? (
        <p class="text-[0.9rem] text-[#666]">the target has no clues yet.</p>
      ) : (
        <div class="flex flex-col">
          {clues.map(c => (
            <div class="flex items-center gap-[0.85rem] border-t border-[#1a1a1a] py-[0.85rem]">
              <div class="flex-1">
                <span class="mb-1 block text-[0.72rem] text-[#888]">{c.prompt}</span>
                <span class="mr-2 text-[0.62rem] uppercase text-[#555]">{c.difficulty}</span>
                <span class="block text-[0.9rem] text-[#ccc]">{c.answer}</span>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </body>
</html>
