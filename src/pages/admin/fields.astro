---
import '../../styles/global.css';
import { db } from '../../lib/db';

const { rows: fields } = await db.execute(
  'SELECT id, prompt, field_order FROM clue_fields ORDER BY field_order, id'
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>pispy — fields</title>
  </head>
  <body>
    <div class="mx-auto w-full max-w-4xl px-5 py-8">
      <nav class="mb-8 flex flex-wrap items-center gap-2 rounded-lg border border-stone-300 bg-white/80 p-2 shadow-[0_8px_22px_rgba(15,23,42,0.06)]">
        <a class="rounded-md px-3 py-2 text-sm font-bold text-slate-600 no-underline hover:bg-amber-100 hover:text-slate-900" href="/admin">Review</a>
        <a class="rounded-md px-3 py-2 text-sm font-bold text-slate-600 no-underline hover:bg-amber-100 hover:text-slate-900" href="/admin/users">Users</a>
        <a class="rounded-md px-3 py-2 text-sm font-black text-slate-900 no-underline hover:bg-amber-100" href="/admin/fields">Fields</a>
        <a class="ml-auto rounded-md px-3 py-2 text-sm font-bold text-slate-600 no-underline hover:bg-amber-100 hover:text-slate-900" href="/api/auth/logout">Log out</a>
      </nav>

      <header class="mb-6">
        <div class="mb-2 text-xs font-black uppercase tracking-wide text-slate-500">Admin</div>
        <h1 class="m-0 text-4xl font-black leading-none text-slate-900">Clue fields</h1>
        <p class="mt-3 max-w-2xl text-base leading-7 text-slate-600">Questions users answer during onboarding. These become clues others use to find them.</p>
      </header>

      {fields.length > 0 && (
        <div class="overflow-x-auto rounded-lg border border-stone-300 bg-white shadow-[0_12px_30px_rgba(15,23,42,0.08)]">
        <table class="w-full border-collapse">
          <thead>
            <tr><th class="px-4 py-3 text-left text-xs font-black uppercase tracking-wide text-slate-500">Order</th><th class="px-4 py-3 text-left text-xs font-black uppercase tracking-wide text-slate-500">Prompt</th><th class="px-4 py-3"></th></tr>
          </thead>
          <tbody>
            {fields.map(f => (
              <tr>
                <td class="border-t border-stone-200 px-4 py-3 font-mono text-xs text-slate-500">{f.field_order as number}</td>
                <td class="border-t border-stone-200 px-4 py-3">
                  <form action="/api/admin/fields" method="POST" class="flex flex-wrap items-center gap-2">
                    <input type="hidden" name="action" value="update" />
                    <input type="hidden" name="id" value={f.id as number} />
                    <input class="min-w-64 flex-1 rounded-md border-2 border-stone-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none transition focus:border-sky-500 focus:ring-4 focus:ring-sky-100" type="text" name="prompt" value={f.prompt as string} />
                    <input class="w-20 rounded-md border-2 border-stone-300 bg-white px-3 py-2 font-mono text-xs text-slate-700 outline-none transition focus:border-sky-500 focus:ring-4 focus:ring-sky-100" type="number" name="field_order" value={f.field_order as number} />
                    <button type="submit" class="inline-flex min-h-9 items-center justify-center rounded-md border-2 border-stone-300 bg-white px-3 py-2 text-sm font-black text-slate-700">Save</button>
                  </form>
                </td>
                <td class="border-t border-stone-200 px-4 py-3 text-right">
                  <form action="/api/admin/fields" method="POST">
                    <input type="hidden" name="action" value="delete" />
                    <input type="hidden" name="id" value={f.id as number} />
                    <button type="submit" class="inline-flex min-h-9 items-center justify-center rounded-md border-2 border-rose-200 bg-white px-3 py-2 text-sm font-black text-rose-700">Remove</button>
                  </form>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
        </div>
      )}

      {fields.length === 0 && <p class="rounded-lg border border-stone-300 bg-white p-4 font-bold text-slate-600">No fields yet.</p>}

      <div class="mt-6 border-t border-stone-300 pt-5">
        <p class="mb-3 text-xs font-black uppercase tracking-wide text-slate-500">Add field</p>
        <form action="/api/admin/fields" method="POST" class="flex flex-wrap gap-3">
          <input type="hidden" name="action" value="create" />
          <input class="min-w-64 flex-1 rounded-md border-2 border-stone-300 bg-white px-3 py-2.5 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-4 focus:ring-sky-100" type="text" name="prompt" placeholder="e.g. what do you usually wear?" required />
          <button type="submit" class="inline-flex min-h-11 items-center justify-center rounded-md border-2 border-slate-900 bg-yellow-300 px-5 py-3 text-sm font-black text-slate-900 shadow-[4px_4px_0_rgba(15,23,42,0.2)] transition hover:-translate-x-0.5 hover:-translate-y-0.5">Add</button>
        </form>
      </div>
    </div>
  </body>
</html>
