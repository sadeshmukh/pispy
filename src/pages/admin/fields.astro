---
import "../../styles/global.css";
import { db } from "../../lib/db";

const { rows: fields } = await db.execute(
	"SELECT id, prompt, field_order, difficulty, question_type, placeholder FROM clue_fields ORDER BY field_order, id",
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>pispy - fields</title>
  </head>
  <body class="bg-[#111] font-sans text-[#ccc]">
    <div class="mx-auto max-w-[700px] px-6 pt-10 pb-16">
      <nav class="mb-10 flex gap-6 border-b border-[#1e1e1e] pb-4 text-[0.8rem]">
        <a href="/admin" class="text-[#666] no-underline hover:text-[#ccc]">review</a>
        <a href="/admin/users" class="text-[#666] no-underline hover:text-[#ccc]">users</a>
        <a href="/admin/fields" class="text-[#666] no-underline hover:text-[#ccc]">fields</a>
        <a href="/admin/assignments" class="text-[#666] no-underline hover:text-[#ccc]">assignments</a>
        <a href="/leaderboard" class="text-[#666] no-underline hover:text-[#ccc]">leaderboard</a>
        <a href="/api/auth/logout" class="ml-auto text-[#666] no-underline hover:text-[#ccc]">leave</a>
      </nav>

      <h1 class="mb-[0.4rem] text-base font-normal text-[#888]">clue fields</h1>
      <p class="mb-7 text-[0.8rem] text-[#555]">questions users answer during onboarding. these become clues others use to find them.</p>

      {fields.length > 0 && (
        <form action="/api/admin/fields" method="POST">
          <input type="hidden" name="action" value="update_all" />
          <table class="mb-4 w-full border-collapse [&_td]:border-t [&_td]:border-[#1a1a1a] [&_td]:py-2 [&_td]:align-middle [&_th]:pb-2 [&_th]:text-left [&_th]:text-[0.65rem] [&_th]:font-normal [&_th]:uppercase [&_th]:tracking-[0.1em] [&_th]:text-[#444]">
            <thead>
              <tr><th>order</th><th>question</th><th></th></tr>
            </thead>
            <tbody>
              {fields.map(f => (
                <tr>
                  <td class="font-mono text-[0.8rem] text-[#555]">{f.field_order as number}</td>
                  <td>
                    <div class="flex items-center gap-2">
                      <input type="hidden" name="id" value={f.id as number} />
                      <div class="grid min-w-0 flex-1 gap-1.5">
                        <input type="text" name={`prompt_${f.id}`} value={f.prompt as string} aria-label="question" class="w-full border border-[#2a2a2a] bg-[#161616] px-[0.6rem] py-[0.35rem] font-sans text-[0.85rem] text-[#ccc] outline-none focus:border-[#444]" />
                        <input type="text" name={`placeholder_${f.id}`} value={f.placeholder as string} placeholder="textbox placeholder (optional)" aria-label="textbox placeholder" class="w-full border border-[#2a2a2a] bg-[#161616] px-[0.6rem] py-[0.35rem] font-sans text-[0.85rem] text-[#ccc] outline-none focus:border-[#444]" />
                      </div>
                      <select name={`difficulty_${f.id}`} aria-label="difficulty" class="w-auto flex-none border border-[#2a2a2a] bg-[#161616] px-[0.6rem] py-[0.35rem] font-sans text-[0.85rem] text-[#ccc] outline-none">
                        {['hard', 'medium', 'easy'].map(level => <option value={level} selected={f.difficulty === level}>{level}</option>)}
                      </select>
                      <select name={`question_type_${f.id}`} aria-label="answer type" class="w-auto flex-none border border-[#2a2a2a] bg-[#161616] px-[0.6rem] py-[0.35rem] font-sans text-[0.85rem] text-[#ccc] outline-none">
                        <option value="text" selected={f.question_type === 'text'}>text</option>
                        <option value="yes_no" selected={f.question_type === 'yes_no'}>yes / no</option>
                      </select>
                      <input type="number" name={`field_order_${f.id}`} value={f.field_order as number} class="w-[52px] flex-none border border-[#2a2a2a] bg-[#161616] px-[0.4rem] py-[0.35rem] font-mono text-[0.75rem] text-[#555] outline-none [-moz-appearance:textfield]" />
                    </div>
                  </td>
                  <td>
                    <label class="ml-2 flex cursor-pointer items-center gap-1.5 whitespace-nowrap text-[0.8rem] text-[#5a3a3a] hover:text-[#aa6a6a]">
                      <input type="checkbox" name="delete" value={f.id as number} class="accent-[#7a4545]" />
                      delete
                    </label>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
          <div class="mb-8 flex justify-end">
            <button type="submit" class="cursor-pointer whitespace-nowrap border border-[#333] bg-none px-4 py-[0.35rem] font-sans text-[0.85rem] text-[#888] transition-colors hover:border-[#555] hover:text-[#ccc]">save fields</button>
          </div>
        </form>
      )}

      {fields.length === 0 && <p class="mb-8 text-[0.9rem] text-[#444]">no fields yet</p>}

      <div class="mt-6 border-t border-[#1e1e1e] pt-6">
        <p class="mb-3 text-[0.65rem] uppercase tracking-[0.1em] text-[#444]">add field</p>
        <form action="/api/admin/fields" method="POST" class="flex gap-3">
          <input type="hidden" name="action" value="create" />
          <div class="grid min-w-0 flex-1 gap-1.5">
            <input type="text" name="prompt" placeholder="e.g. what do you usually wear?" aria-label="question" required class="w-full border border-[#2a2a2a] bg-[#161616] px-[0.6rem] py-[0.35rem] font-sans text-[0.85rem] text-[#ccc] outline-none focus:border-[#444]" />
            <input type="text" name="placeholder" placeholder="textbox placeholder (optional)" aria-label="textbox placeholder" class="w-full border border-[#2a2a2a] bg-[#161616] px-[0.6rem] py-[0.35rem] font-sans text-[0.85rem] text-[#ccc] outline-none focus:border-[#444]" />
          </div>
          <select name="difficulty" aria-label="difficulty" class="w-auto flex-none border border-[#2a2a2a] bg-[#161616] px-[0.6rem] py-[0.35rem] font-sans text-[0.85rem] text-[#ccc] outline-none"><option value="hard">hard</option><option value="medium" selected>medium</option><option value="easy">easy</option></select>
          <select name="question_type" aria-label="answer type" class="w-auto flex-none border border-[#2a2a2a] bg-[#161616] px-[0.6rem] py-[0.35rem] font-sans text-[0.85rem] text-[#ccc] outline-none"><option value="text">text</option><option value="yes_no">yes / no</option></select>
          <button type="submit" class="cursor-pointer whitespace-nowrap border border-[#333] bg-none px-4 py-[0.35rem] font-sans text-[0.85rem] text-[#888] transition-colors hover:border-[#555] hover:text-[#ccc]">add</button>
        </form>
      </div>
    </div>
  </body>
</html>
