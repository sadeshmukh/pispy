---
import { db } from '../../lib/db';

const { rows: fields } = await db.execute(
  'SELECT id, prompt, field_order FROM clue_fields ORDER BY field_order, id'
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>pispy — fields</title>
  </head>
  <body>
    <div class="page">
      <nav>
        <a href="/admin">review</a>
        <a href="/admin/users">users</a>
        <a href="/admin/fields">fields</a>
        <a href="/api/auth/logout" class="logout">leave</a>
      </nav>

      <h1>clue fields</h1>
      <p class="sub">questions users answer during onboarding. these become clues others use to find them.</p>

      {fields.length > 0 && (
        <table>
          <thead>
            <tr><th>order</th><th>prompt</th><th></th></tr>
          </thead>
          <tbody>
            {fields.map(f => (
              <tr>
                <td class="muted mono">{f.field_order as number}</td>
                <td>
                  <form action="/api/admin/fields" method="POST" class="inline-form">
                    <input type="hidden" name="action" value="update" />
                    <input type="hidden" name="id" value={f.id as number} />
                    <input type="text" name="prompt" value={f.prompt as string} />
                    <input type="number" name="field_order" value={f.field_order as number} class="order-input" />
                    <button type="submit" class="btn-ghost">save</button>
                  </form>
                </td>
                <td>
                  <form action="/api/admin/fields" method="POST">
                    <input type="hidden" name="action" value="delete" />
                    <input type="hidden" name="id" value={f.id as number} />
                    <button type="submit" class="btn-delete">remove</button>
                  </form>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}

      {fields.length === 0 && <p class="empty">no fields yet</p>}

      <div class="add-section">
        <p class="add-label">add field</p>
        <form action="/api/admin/fields" method="POST" class="add-form">
          <input type="hidden" name="action" value="create" />
          <input type="text" name="prompt" placeholder="e.g. what do you usually wear?" required />
          <button type="submit" class="btn-add">add</button>
        </form>
      </div>
    </div>
  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { background: #111; color: #ccc; font-family: Georgia, serif; }
  .page { max-width: 700px; margin: 0 auto; padding: 2.5rem 1.5rem 4rem; }
  nav {
    display: flex; gap: 1.5rem; margin-bottom: 2.5rem;
    padding-bottom: 1rem; border-bottom: 1px solid #1e1e1e;
    font-size: 0.8rem; font-style: italic;
  }
  nav a { color: #666; text-decoration: none; }
  nav a:hover { color: #ccc; }
  nav .logout { margin-left: auto; }
  h1 { font-size: 1rem; font-weight: normal; font-style: italic; color: #888; margin-bottom: 0.4rem; }
  .sub { font-size: 0.8rem; color: #555; font-style: italic; margin-bottom: 1.75rem; }

  table { width: 100%; border-collapse: collapse; margin-bottom: 2rem; }
  th { font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: #444; font-weight: normal; padding: 0 0 0.5rem; text-align: left; }
  td { padding: 0.5rem 0; border-top: 1px solid #1a1a1a; vertical-align: middle; }
  .muted { color: #555; font-size: 0.8rem; }
  .mono { font-family: ui-monospace, monospace; }

  .inline-form { display: flex; gap: 0.5rem; align-items: center; }
  input[type="text"] {
    background: #161616; border: 1px solid #2a2a2a; color: #ccc;
    font-family: Georgia, serif; font-size: 0.85rem; font-style: italic;
    padding: 0.35rem 0.6rem; outline: none; flex: 1;
  }
  input[type="text"]:focus { border-color: #444; }
  .order-input {
    background: #161616; border: 1px solid #2a2a2a; color: #555;
    font-family: ui-monospace, monospace; font-size: 0.75rem;
    padding: 0.35rem 0.4rem; outline: none; width: 52px; flex: none;
  }
  input[type="number"] { -moz-appearance: textfield; }

  .btn-ghost {
    background: none; border: none; color: #555; font-family: Georgia, serif;
    font-size: 0.8rem; font-style: italic; cursor: pointer; padding: 0.2rem 0;
    white-space: nowrap;
  }
  .btn-ghost:hover { color: #999; }
  .btn-delete {
    background: none; border: none; color: #5a3a3a; font-family: Georgia, serif;
    font-size: 0.8rem; font-style: italic; cursor: pointer; padding: 0.2rem 0;
  }
  .btn-delete:hover { color: #aa6a6a; }

  .empty { font-size: 0.9rem; font-style: italic; color: #444; margin-bottom: 2rem; }

  .add-section { margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid #1e1e1e; }
  .add-label { font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: #444; margin-bottom: 0.75rem; }
  .add-form { display: flex; gap: 0.75rem; }
  .btn-add {
    background: none; border: 1px solid #333; color: #888;
    font-family: Georgia, serif; font-size: 0.85rem; font-style: italic;
    padding: 0.35rem 1rem; cursor: pointer; white-space: nowrap;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-add:hover { border-color: #555; color: #ccc; }
</style>
