---
import '../../styles/global.css';
import { db } from '../../lib/db';

const { rows: users } = await db.execute(
  'SELECT slack_id, display_name, onboarding_status, created_at FROM users ORDER BY created_at DESC'
);

const statusLabel: Record<string, string> = {
  pending_submission: 'not submitted',
  pending_review: 'pending',
  approved: 'approved',
  changes_requested: 'changes requested',
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>pispy — users</title>
  </head>
  <body>
    <div class="mx-auto w-full max-w-5xl px-5 py-8">
      <nav class="mb-8 flex flex-wrap items-center gap-2 rounded-lg border border-stone-300 bg-white/80 p-2 shadow-[0_8px_22px_rgba(15,23,42,0.06)]">
        <a class="rounded-md px-3 py-2 text-sm font-bold text-slate-600 no-underline hover:bg-amber-100 hover:text-slate-900" href="/admin">Review</a>
        <a class="rounded-md px-3 py-2 text-sm font-black text-slate-900 no-underline hover:bg-amber-100" href="/admin/users">Users</a>
        <a class="ml-auto rounded-md px-3 py-2 text-sm font-bold text-slate-600 no-underline hover:bg-amber-100 hover:text-slate-900" href="/api/auth/logout">Log out</a>
      </nav>

      <header class="mb-6">
        <div class="mb-2 text-xs font-black uppercase tracking-wide text-slate-500">Admin</div>
        <h1 class="m-0 text-4xl font-black leading-none text-slate-900">All users ({users.length})</h1>
      </header>

      {users.length === 0 ? (
        <p class="rounded-lg border border-stone-300 bg-white p-4 font-bold text-slate-600">No users yet.</p>
      ) : (
        <div class="overflow-x-auto rounded-lg border border-stone-300 bg-white shadow-[0_12px_30px_rgba(15,23,42,0.08)]">
        <table class="w-full border-collapse">
          <thead>
            <tr>
              <th class="px-4 py-3 text-left text-xs font-black uppercase tracking-wide text-slate-500">Name</th>
              <th class="px-4 py-3 text-left text-xs font-black uppercase tracking-wide text-slate-500">Slack ID</th>
              <th class="px-4 py-3 text-left text-xs font-black uppercase tracking-wide text-slate-500">Status</th>
              <th class="px-4 py-3 text-left text-xs font-black uppercase tracking-wide text-slate-500">Joined</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody>
            {users.map(u => (
              <tr>
                <td class="border-t border-stone-200 px-4 py-3 text-sm font-bold text-slate-900">{u.display_name as string}</td>
                <td class="border-t border-stone-200 px-4 py-3 font-mono text-xs text-slate-500">{u.slack_id as string}</td>
                <td class={`border-t border-stone-200 px-4 py-3 text-sm font-black ${u.onboarding_status === 'approved' ? 'text-emerald-700' : u.onboarding_status === 'pending_review' ? 'text-amber-700' : u.onboarding_status === 'changes_requested' ? 'text-rose-700' : 'text-slate-500'}`}>
                  {statusLabel[u.onboarding_status as string] ?? u.onboarding_status as string}
                </td>
                <td class="border-t border-stone-200 px-4 py-3 text-sm text-slate-500">{new Date((u.created_at as number) * 1000).toLocaleDateString()}</td>
                <td class="border-t border-stone-200 px-4 py-3 text-right text-sm">
                  {u.onboarding_status !== 'pending_submission' && (
                    <a class="font-black text-sky-700 no-underline" href={`/admin/review/${u.slack_id}`}>{u.onboarding_status === 'pending_review' ? 'Review' : 'View'}</a>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
        </div>
      )}
    </div>
  </body>
</html>
