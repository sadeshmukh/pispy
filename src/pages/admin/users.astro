---
import { db } from '../../lib/db';

const { rows: users } = await db.execute(
  'SELECT slack_id, display_name, onboarding_status, created_at FROM users ORDER BY created_at DESC'
);

const statusLabel: Record<string, string> = {
  pending_submission: 'not submitted',
  pending_review: 'pending',
  approved: 'approved',
  changes_requested: 'changes requested',
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>pispy — users</title>
  </head>
  <body>
    <div class="page">
      <nav>
        <a href="/admin">review</a>
        <a href="/admin/users">users</a>
        <a href="/admin/fields">fields</a>
        <a href="/admin/assignments">assignments</a>
        <a href="/leaderboard">leaderboard</a>
        <a href="/api/auth/logout" class="logout">leave</a>
      </nav>

      <h1>all users ({users.length})</h1>

      {users.length === 0 ? (
        <p class="empty">no users yet</p>
      ) : (
        <table>
          <thead>
            <tr><th>name</th><th>slack id</th><th>status</th><th>joined</th><th></th></tr>
          </thead>
          <tbody>
            {users.map(u => (
              <tr>
                <td>{u.display_name as string}</td>
                <td class="muted mono">{u.slack_id as string}</td>
                <td class={`status-${u.onboarding_status as string}`}>
                  {statusLabel[u.onboarding_status as string] ?? u.onboarding_status as string}
                </td>
                <td class="muted">{new Date((u.created_at as number) * 1000).toLocaleDateString()}</td>
                <td class="row-links">
                  {u.onboarding_status === 'pending_review' && (
                    <a href={`/admin/review/${u.slack_id}`}>review</a>
                  )}
                  <a href={`/admin/inspect/${u.slack_id}`}>inspect →</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { background: #111; color: #ccc; font-family: system-ui, -apple-system, sans-serif; }
  .page { max-width: 800px; margin: 0 auto; padding: 2.5rem 1.5rem; }
  nav {
    display: flex; gap: 1.5rem; margin-bottom: 2.5rem;
    padding-bottom: 1rem; border-bottom: 1px solid #1e1e1e;
    font-size: 0.8rem;
  }
  nav a { color: #666; text-decoration: none; }
  nav a:hover { color: #ccc; }
  nav .logout { margin-left: auto; }
  h1 { font-size: 1rem; font-weight: normal; color: #888; margin-bottom: 1.25rem; }
  .empty { font-size: 0.9rem; color: #444; }
  table { width: 100%; border-collapse: collapse; }
  th { font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: #444; font-weight: normal; padding: 0 0 0.5rem; text-align: left; }
  td { padding: 0.65rem 0; border-top: 1px solid #1a1a1a; font-size: 0.875rem; }
  td a { color: #888; text-decoration: none; }
  td a:hover { color: #ccc; }
  .muted { color: #555; font-size: 0.8rem; }
  .mono { font-family: ui-monospace, monospace; font-size: 0.75rem; }
  .status-approved { color: #5a7a5a; }
  .status-pending_review { color: #7a7a4a; }
  .status-changes_requested { color: #7a4a4a; }
  .status-pending_submission { color: #555; }
  .row-links { display: flex; gap: 1rem; justify-content: flex-end; }
</style>
