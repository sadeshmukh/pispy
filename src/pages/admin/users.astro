---
import '../../styles/global.css';
import { db } from '../../lib/db';

const { rows: users } = await db.execute(
  'SELECT slack_id, display_name, onboarding_status, created_at FROM users ORDER BY created_at DESC'
);

const statusLabel: Record<string, string> = {
  pending_submission: 'not submitted',
  pending_review: 'pending',
  approved: 'approved',
  changes_requested: 'changes requested',
};

const statusClass: Record<string, string> = {
  approved: 'text-[#5a7a5a]',
  pending_review: 'text-[#7a7a4a]',
  changes_requested: 'text-[#7a4a4a]',
  pending_submission: 'text-[#555]',
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>pispy — users</title>
  </head>
  <body class="bg-[#111] font-sans text-[#ccc]">
    <div class="mx-auto max-w-[800px] px-6 py-10">
      <nav class="mb-10 flex gap-6 border-b border-[#1e1e1e] pb-4 text-[0.8rem]">
        <a href="/admin" class="text-[#666] no-underline hover:text-[#ccc]">review</a>
        <a href="/admin/users" class="text-[#666] no-underline hover:text-[#ccc]">users</a>
        <a href="/admin/fields" class="text-[#666] no-underline hover:text-[#ccc]">fields</a>
        <a href="/admin/assignments" class="text-[#666] no-underline hover:text-[#ccc]">assignments</a>
        <a href="/leaderboard" class="text-[#666] no-underline hover:text-[#ccc]">leaderboard</a>
        <a href="/api/auth/logout" class="ml-auto text-[#666] no-underline hover:text-[#ccc]">leave</a>
      </nav>

      <h1 class="mb-5 text-base font-normal text-[#888]">all users ({users.length})</h1>

      {users.length === 0 ? (
        <p class="text-[0.9rem] text-[#444]">no users yet</p>
      ) : (
        <table class="w-full border-collapse [&_td]:border-t [&_td]:border-[#1a1a1a] [&_td]:py-[0.65rem] [&_td]:text-[0.875rem] [&_td_a]:text-[#888] [&_td_a]:no-underline [&_td_a:hover]:text-[#ccc] [&_th]:pb-2 [&_th]:text-left [&_th]:text-[0.65rem] [&_th]:font-normal [&_th]:uppercase [&_th]:tracking-[0.1em] [&_th]:text-[#444]">
          <thead>
            <tr><th>name</th><th>slack id</th><th>status</th><th>joined</th><th></th></tr>
          </thead>
          <tbody>
            {users.map(u => (
              <tr>
                <td>{u.display_name as string}</td>
                <td class="font-mono !text-[0.75rem] text-[#555]">{u.slack_id as string}</td>
                <td class={statusClass[u.onboarding_status as string] ?? ''}>
                  {statusLabel[u.onboarding_status as string] ?? u.onboarding_status as string}
                </td>
                <td class="!text-[0.8rem] text-[#555]">{new Date((u.created_at as number) * 1000).toLocaleDateString()}</td>
                <td class="flex justify-end gap-4">
                  {u.onboarding_status === 'pending_review' && (
                    <a href={`/admin/review/${u.slack_id}`}>review</a>
                  )}
                  <a href={`/admin/inspect/${u.slack_id}`}>inspect →</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </body>
</html>
