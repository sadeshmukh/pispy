---
import '../../styles/global.css';
import { db } from '../../lib/db';

const { rows: pending } = await db.execute(
  `SELECT slack_id, display_name, created_at FROM users WHERE onboarding_status = 'pending_review' ORDER BY created_at ASC`
);
const { rows: all } = await db.execute(
  `SELECT onboarding_status, COUNT(*) as count FROM users GROUP BY onboarding_status`
);
const counts = Object.fromEntries(all.map(r => [r.onboarding_status as string, r.count as number]));

// Submitted captures waiting for an admin to confirm the find.
const { rows: captures } = await db.execute(`
  SELECT a.id, a.submitted_at, a.score,
         h.display_name AS hunter_name,
         t.display_name AS target_name
  FROM assignments a
  JOIN users h ON h.slack_id = a.hunter_id
  JOIN users t ON t.slack_id = a.target_id
  WHERE a.status = 'submitted'
  ORDER BY a.submitted_at ASC
`);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>pispy — admin</title>
  </head>
  <body class="bg-[#111] font-sans text-[#ccc]">
    <div class="mx-auto max-w-[700px] px-6 py-10">
      <nav class="mb-10 flex gap-6 border-b border-[#1e1e1e] pb-4 text-[0.85rem]">
        <a href="/admin" class="text-[#888] no-underline hover:text-[#ccc]">review</a>
        <a href="/admin/users" class="text-[#888] no-underline hover:text-[#ccc]">users</a>
        <a href="/admin/fields" class="text-[#888] no-underline hover:text-[#ccc]">fields</a>
        <a href="/admin/assignments" class="text-[#888] no-underline hover:text-[#ccc]">assignments</a>
        <a href="/leaderboard" class="text-[#888] no-underline hover:text-[#ccc]">leaderboard</a>
        <a href="/api/auth/logout" class="ml-auto text-[#888] no-underline hover:text-[#ccc]">leave</a>
      </nav>

      <div class="mb-8 flex flex-wrap gap-6">
        {Object.entries(counts).map(([status, count]) => (
          <span class="text-[0.78rem] text-[#888]">{count} {status.replace('_', ' ')}</span>
        ))}
      </div>

      <h1 class="mb-4 text-[1.05rem] font-semibold text-[#ddd]">captures to confirm</h1>
      {captures.length === 0 ? (
        <p class="text-[0.9rem] text-[#666]">no submissions waiting</p>
      ) : (
        <table class="w-full border-collapse [&_td]:border-t [&_td]:border-[#1a1a1a] [&_td]:py-[0.65rem] [&_td]:text-[0.875rem] [&_td_a]:text-[#999] [&_td_a]:no-underline [&_td_a:hover]:text-[#ccc] [&_th]:pb-2 [&_th]:text-left [&_th]:text-[0.65rem] [&_th]:font-semibold [&_th]:uppercase [&_th]:tracking-[0.1em] [&_th]:text-[#777]">
          <thead>
            <tr><th>hunter</th><th>target</th><th>submitted</th><th>worth</th><th></th></tr>
          </thead>
          <tbody>
            {captures.map(c => (
              <tr>
                <td>{c.hunter_name as string}</td>
                <td>{c.target_name as string}</td>
                <td class="!text-[0.8rem] text-[#777]">{new Date((c.submitted_at as number) * 1000).toLocaleString()}</td>
                <td class="font-mono !text-[0.75rem] text-[#777]">{c.score as number} pts</td>
                <td><a href={`/admin/assignment/${c.id}`}>review →</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      )}

      <h1 class="mt-10 mb-4 text-[1.05rem] font-semibold text-[#ddd]">onboarding to review</h1>
      {pending.length === 0 ? (
        <p class="text-[0.9rem] text-[#666]">nothing to review</p>
      ) : (
        <table class="w-full border-collapse [&_td]:border-t [&_td]:border-[#1a1a1a] [&_td]:py-[0.65rem] [&_td]:text-[0.875rem] [&_td_a]:text-[#999] [&_td_a]:no-underline [&_td_a:hover]:text-[#ccc] [&_th]:pb-2 [&_th]:text-left [&_th]:text-[0.65rem] [&_th]:font-semibold [&_th]:uppercase [&_th]:tracking-[0.1em] [&_th]:text-[#777]">
          <thead>
            <tr><th>name</th><th>submitted</th><th></th></tr>
          </thead>
          <tbody>
            {pending.map(u => (
              <tr>
                <td>{u.display_name as string}</td>
                <td class="!text-[0.8rem] text-[#777]">{new Date((u.created_at as number) * 1000).toLocaleDateString()}</td>
                <td><a href={`/admin/review/${u.slack_id}`}>review →</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </body>
</html>
