---
import '../../styles/global.css';
import { db } from '../../lib/db';

const { rows: pending } = await db.execute(
  `SELECT slack_id, display_name, created_at FROM users WHERE onboarding_status = 'pending_review' ORDER BY created_at ASC`
);
const { rows: all } = await db.execute(
  `SELECT onboarding_status, COUNT(*) as count FROM users GROUP BY onboarding_status`
);
const counts = Object.fromEntries(all.map(r => [r.onboarding_status as string, r.count as number]));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>pispy — admin</title>
  </head>
  <body>
    <div class="mx-auto w-full max-w-4xl px-5 py-8">
      <nav class="mb-8 flex flex-wrap items-center gap-2 rounded-lg border border-stone-300 bg-white/80 p-2 shadow-[0_8px_22px_rgba(15,23,42,0.06)]">
        <a class="rounded-md px-3 py-2 text-sm font-black text-slate-900 no-underline hover:bg-amber-100" href="/admin">Review</a>
        <a class="rounded-md px-3 py-2 text-sm font-bold text-slate-600 no-underline hover:bg-amber-100 hover:text-slate-900" href="/admin/users">Users</a>
        <a class="rounded-md px-3 py-2 text-sm font-bold text-slate-600 no-underline hover:bg-amber-100 hover:text-slate-900" href="/admin/fields">Fields</a>
        <a class="ml-auto rounded-md px-3 py-2 text-sm font-bold text-slate-600 no-underline hover:bg-amber-100 hover:text-slate-900" href="/api/auth/logout">Log out</a>
      </nav>

      <header class="mb-6">
        <div class="mb-2 text-xs font-black uppercase tracking-wide text-slate-500">Admin</div>
        <h1 class="m-0 text-4xl font-black leading-none text-slate-900">Pending review</h1>
      </header>

      <div class="mb-4 flex flex-wrap gap-2">
        {Object.entries(counts).map(([status, count]) => (
          <span class="rounded-full border border-stone-300 bg-white px-3 py-1.5 text-sm font-black text-slate-600">{count} {status.replace('_', ' ')}</span>
        ))}
      </div>

      {pending.length === 0 ? (
        <p class="rounded-lg border border-stone-300 bg-white p-4 font-bold text-slate-600">Nothing to review.</p>
      ) : (
        <div class="overflow-x-auto rounded-lg border border-stone-300 bg-white shadow-[0_12px_30px_rgba(15,23,42,0.08)]">
        <table class="w-full border-collapse">
          <thead>
            <tr><th class="px-4 py-3 text-left text-xs font-black uppercase tracking-wide text-slate-500">Name</th><th class="px-4 py-3 text-left text-xs font-black uppercase tracking-wide text-slate-500">Submitted</th><th class="px-4 py-3"></th></tr>
          </thead>
          <tbody>
            {pending.map(u => (
              <tr>
                <td class="border-t border-stone-200 px-4 py-3 text-sm font-bold text-slate-900">{u.display_name as string}</td>
                <td class="border-t border-stone-200 px-4 py-3 text-sm text-slate-500">{new Date((u.created_at as number) * 1000).toLocaleDateString()}</td>
                <td class="border-t border-stone-200 px-4 py-3 text-right text-sm"><a class="font-black text-sky-700 no-underline" href={`/admin/review/${u.slack_id}`}>Review</a></td>
              </tr>
            ))}
          </tbody>
        </table>
        </div>
      )}
    </div>
  </body>
</html>
