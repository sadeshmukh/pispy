---
import "../../../styles/global.css";
import { db } from "../../../lib/db";

const { slack_id } = Astro.params;

const { rows } = await db.execute({
	sql: "SELECT display_name, avatar_url, onboarding_status, about_text FROM users WHERE slack_id = ?",
	args: [slack_id!],
});
if (!rows[0]) return Astro.redirect("/admin");

const user = rows[0];
const aboutText = (user.about_text as string | null)?.trim();

const { rows: clues } = await db.execute({
	sql: `SELECT cf.prompt, uc.answer, cf.difficulty, cf.question_type
        FROM user_clues uc
        JOIN clue_fields cf ON cf.id = uc.field_id
        WHERE uc.slack_id = ?
        ORDER BY cf.field_order, cf.id`,
	args: [slack_id!],
});
const { rows: customClues } = await db.execute({
	sql: "SELECT id, clue, difficulty, source FROM custom_clues WHERE slack_id = ? ORDER BY source DESC, id",
	args: [slack_id!],
});
const aiClues = customClues.filter((c) => c.source === "ai");
const userClues = customClues.filter((c) => c.source !== "ai");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>pispy — review {user.display_name as string}</title>
  </head>
  <body class="bg-[#111] font-sans text-[#ccc]">
    <div class="mx-auto max-w-[700px] px-6 pt-10 pb-16">
      <nav class="mb-10 flex gap-6 border-b border-[#1e1e1e] pb-4 text-[0.8rem]">
        <a href="/admin" class="text-[#666] no-underline hover:text-[#ccc]">← back</a>
        <a href="/admin/users" class="text-[#666] no-underline hover:text-[#ccc]">users</a>
        <a href="/admin/fields" class="text-[#666] no-underline hover:text-[#ccc]">fields</a>
        <a href="/admin/assignments" class="text-[#666] no-underline hover:text-[#ccc]">assignments</a>
        <a href={`/admin/inspect/${slack_id}`} class="text-[#666] no-underline hover:text-[#ccc]">inspect</a>
        <a href="/api/auth/logout" class="ml-auto text-[#666] no-underline hover:text-[#ccc]">leave</a>
      </nav>

      <header class="mb-8 flex items-center gap-4">
        {user.avatar_url && <img src={user.avatar_url as string} alt="" class="h-12 w-12 rounded-full object-cover grayscale-[20%]" />}
        <div>
          <h1 class="mb-[0.15rem] text-[1.1rem] font-normal text-[#ddd]">{user.display_name as string}</h1>
          <p class="font-mono text-[0.75rem] text-[#555]">{slack_id}</p>
        </div>
      </header>

      <div class="mb-8 grid grid-cols-2 gap-4">
        <div>
          <p class="mb-[0.4rem] text-[0.65rem] uppercase tracking-[0.1em] text-[#555]">badge</p>
          <img src={`/api/photos/${slack_id}/badge`} alt="badge photo" class="block aspect-[4/3] w-full border border-[#222] bg-[#161616] object-cover" />
        </div>
        <div>
          <p class="mb-[0.4rem] text-[0.65rem] uppercase tracking-[0.1em] text-[#555]">face</p>
          <img src={`/api/photos/${slack_id}/face`} alt="face photo" class="block aspect-[4/3] w-full border border-[#222] bg-[#161616] object-cover" />
        </div>
      </div>

      {clues.length > 0 && (
        <div class="mb-8">
          <p class="mb-3 text-[0.65rem] uppercase tracking-[0.1em] text-[#444]">clues</p>
          {clues.map(c => (
            <div class="flex items-baseline gap-4 border-t border-[#1a1a1a] py-2">
              <span class="min-w-[140px] text-[0.75rem] text-[#555]">{c.prompt as string}</span>
              <span class="text-[0.875rem] text-[#ccc]">{c.answer as string} <span class="ml-[0.4rem] text-[0.62rem] uppercase text-[#555]">{c.difficulty as string}</span></span>
            </div>
          ))}
        </div>
      )}

      {aboutText && (
        <div class="mb-8">
          <p class="mb-2 text-[0.65rem] uppercase tracking-[0.1em] text-[#444]">what they wrote about themselves</p>
          <p class="whitespace-pre-wrap border-l-2 border-[#2a2a2a] bg-[#141414] px-4 py-3 text-[0.85rem] leading-[1.55] text-[#aaa]">{aboutText}</p>
        </div>
      )}

      {(aiClues.length > 0 || aboutText) && (
        <div class="mb-8">
          <div class="mb-3 flex items-center justify-between gap-4">
            <p class="text-[0.65rem] uppercase tracking-[0.1em] text-[#6a7a8a]">AI-generated clues — sign off before approving</p>
            <form action="/api/admin/review" method="POST">
              <input type="hidden" name="slack_id" value={slack_id} />
              <input type="hidden" name="action" value="regenerate_clues" />
              <button type="submit" class="cursor-pointer border border-[#2a3a4a] bg-none px-3 py-[0.35rem] font-sans text-[0.75rem] text-[#6a8aaa] transition-colors hover:border-[#4a6a8a] hover:text-[#8aaaca]">regenerate from description</button>
            </form>
          </div>
          {aiClues.length === 0 ? (
            <p class="text-[0.82rem] text-[#666]">No AI clues yet — regenerate to create some from the description above.</p>
          ) : (
            <form action="/api/admin/review" method="POST" class="flex flex-col items-start gap-[0.65rem]">
              <input type="hidden" name="slack_id" value={slack_id} />
              <input type="hidden" name="action" value="save_custom_clues" />
              {aiClues.map(c => (
                <div class="grid w-full grid-cols-[1fr_auto_auto] items-center gap-[0.6rem]">
                  <input type="text" name={`custom_clue_${c.id}`} value={c.clue as string} required class="border border-[#2a3340] bg-[#141a20] px-[0.65rem] py-2 font-sans text-base text-[#ccc] outline-none" />
                  <select name={`custom_difficulty_${c.id}`} class="border border-[#2a2a2a] bg-[#161616] px-[0.65rem] py-2 font-sans text-base text-[#ccc] outline-none">
                    {['hard', 'medium', 'easy'].map(level => <option value={level} selected={c.difficulty === level}>{level}</option>)}
                  </select>
                  <label class="text-[0.75rem] text-[#755]"><input type="checkbox" name={`delete_custom_${c.id}`} /> remove</label>
                </div>
              ))}
              <button type="submit" class="cursor-pointer border border-[#333] bg-none px-4 py-2 font-sans text-[0.85rem] text-[#888] transition-colors hover:border-[#555] hover:text-[#bbb]">save AI clues</button>
            </form>
          )}
        </div>
      )}

      {userClues.length > 0 && (
        <div class="mb-8">
          <p class="mb-3 text-[0.65rem] uppercase tracking-[0.1em] text-[#444]">their own clues — editable before approval</p>
          <form action="/api/admin/review" method="POST" class="flex flex-col items-start gap-[0.65rem]">
            <input type="hidden" name="slack_id" value={slack_id} />
            <input type="hidden" name="action" value="save_custom_clues" />
            {userClues.map(c => (
              <div class="grid w-full grid-cols-[1fr_auto_auto] items-center gap-[0.6rem]">
                <input type="text" name={`custom_clue_${c.id}`} value={c.clue as string} required class="border border-[#2a2a2a] bg-[#161616] px-[0.65rem] py-2 font-sans text-base text-[#ccc] outline-none" />
                <select name={`custom_difficulty_${c.id}`} class="border border-[#2a2a2a] bg-[#161616] px-[0.65rem] py-2 font-sans text-base text-[#ccc] outline-none">
                  {['hard', 'medium', 'easy'].map(level => <option value={level} selected={c.difficulty === level}>{level}</option>)}
                </select>
                <label class="text-[0.75rem] text-[#755]"><input type="checkbox" name={`delete_custom_${c.id}`} /> remove</label>
              </div>
            ))}
            <button type="submit" class="cursor-pointer border border-[#333] bg-none px-4 py-2 font-sans text-[0.85rem] text-[#888] transition-colors hover:border-[#555] hover:text-[#bbb]">save their clues</button>
          </form>
        </div>
      )}

      <div class="flex items-start gap-8">
        <form action="/api/admin/review" method="POST">
          <input type="hidden" name="slack_id" value={slack_id} />
          <input type="hidden" name="action" value="approve" />
          <button type="submit" class="cursor-pointer whitespace-nowrap border border-[#3a5a3a] bg-none px-5 py-2 font-sans text-[0.85rem] text-[#5a8a5a] transition-colors hover:border-[#5a8a5a] hover:text-[#7aaa7a]">approve</button>
        </form>

        <form action="/api/admin/review" method="POST" class="flex flex-1 flex-col gap-2">
          <input type="hidden" name="slack_id" value={slack_id} />
          <input type="hidden" name="action" value="request_changes" />
          <textarea name="note" placeholder="what needs to change..." rows="3" class="resize-y border border-[#2a2a2a] bg-[#161616] px-[0.65rem] py-2 font-sans text-[0.85rem] text-[#ccc] outline-none focus:border-[#444]"></textarea>
          <button type="submit" class="cursor-pointer border border-[#333] bg-none px-4 py-2 font-sans text-[0.85rem] text-[#888] transition-colors hover:border-[#555] hover:text-[#bbb]">request changes</button>
        </form>
      </div>
    </div>
  </body>
</html>
