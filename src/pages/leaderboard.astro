---
import "../styles/global.css";
import { getSession } from "../lib/auth";
import { db } from "../lib/db";

const session = getSession(Astro.cookies);
if (!session) return Astro.redirect("/");

// Points per hunter: the sum of every confirmed find's score. Hunters with no
// confirmed find yet show up with zero so everyone can see the board.
const { rows } = await db.execute(`
  SELECT
    u.slack_id,
    u.display_name,
    u.avatar_url,
    COALESCE(SUM(CASE WHEN a.status = 'completed' THEN a.score END), 0) AS points,
    COUNT(CASE WHEN a.status = 'completed' THEN 1 END) AS finds
  FROM users u
  LEFT JOIN assignments a ON a.hunter_id = u.slack_id
  WHERE u.onboarding_status = 'approved'
  GROUP BY u.slack_id
  ORDER BY points DESC, u.display_name ASC
`);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" />
    <title>pispy — leaderboard</title>
  </head>
  <body class="bg-[#111] font-sans text-[#ccc]">
    <div class="mx-auto max-w-[560px] px-6 pt-10 pb-16">
      <nav class="mb-10 flex gap-6 border-b border-[#1e1e1e] pb-4 text-[0.85rem]">
        <a href="/" class="text-[#888] no-underline hover:text-[#ccc]">home</a>
        <a href="/hunt" class="text-[#888] no-underline hover:text-[#ccc]">hunt</a>
        <a href="/api/auth/logout" class="ml-auto text-[#888] no-underline hover:text-[#ccc]">log out</a>
      </nav>

      <h1 class="mb-6 text-[1.15rem] font-semibold text-[#ddd]">Leaderboard</h1>

      {rows.length === 0 ? (
        <p class="text-[0.9rem] text-[#666]">No players yet.</p>
      ) : (
        <ol class="flex list-none flex-col">
          {rows.map((r, i) => (
            <li class={`flex items-center gap-[0.9rem] border-t border-[#1a1a1a] py-3 ${r.slack_id === session.slack_id ? '-mx-3 rounded-md border-t-transparent bg-[#161616] px-3' : ''}`}>
              <span class="w-6 text-right text-[0.9rem] tabular-nums text-[#777]">{i + 1}</span>
              {r.avatar_url && <img src={r.avatar_url as string} alt="" class="h-7 w-7 rounded-full object-cover" />}
              <span class="flex-1 text-[0.95rem] text-[#ddd]">{r.display_name as string}</span>
              <span class="text-[0.78rem] text-[#777]">{r.finds as number} {(r.finds as number) === 1 ? 'find' : 'finds'}</span>
              <span class="min-w-[3rem] text-right text-base font-semibold tabular-nums text-[#6a9aba]">{r.points as number}</span>
            </li>
          ))}
        </ol>
      )}
    </div>
  </body>
</html>
