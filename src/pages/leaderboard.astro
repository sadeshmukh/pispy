---
import { getSession } from '../lib/auth';
import { db } from '../lib/db';

const session = getSession(Astro.cookies);
if (!session) return Astro.redirect('/');

// Points per hunter: the sum of every confirmed find's score. Hunters with no
// confirmed find yet show up with zero so everyone can see the board.
const { rows } = await db.execute(`
  SELECT
    u.slack_id,
    u.display_name,
    u.avatar_url,
    COALESCE(SUM(CASE WHEN a.status = 'completed' THEN a.score END), 0) AS points,
    COUNT(CASE WHEN a.status = 'completed' THEN 1 END) AS finds
  FROM users u
  LEFT JOIN assignments a ON a.hunter_id = u.slack_id
  WHERE u.onboarding_status = 'approved'
  GROUP BY u.slack_id
  ORDER BY points DESC, u.display_name ASC
`);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" />
    <title>pispy — leaderboard</title>
  </head>
  <body>
    <div class="page">
      <nav>
        <a href="/">home</a>
        <a href="/hunt">hunt</a>
        <a href="/api/auth/logout" class="logout">log out</a>
      </nav>

      <h1>Leaderboard</h1>

      {rows.length === 0 ? (
        <p class="empty">No players yet.</p>
      ) : (
        <ol class="board">
          {rows.map((r, i) => (
            <li class={r.slack_id === session.slack_id ? 'me' : ''}>
              <span class="rank">{i + 1}</span>
              {r.avatar_url && <img src={r.avatar_url as string} alt="" class="avatar" />}
              <span class="name">{r.display_name as string}</span>
              <span class="finds">{r.finds as number} {(r.finds as number) === 1 ? 'find' : 'finds'}</span>
              <span class="points">{r.points as number}</span>
            </li>
          ))}
        </ol>
      )}
    </div>
  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { background: #111; color: #ccc; font-family: system-ui, -apple-system, sans-serif; }
  .page { max-width: 560px; margin: 0 auto; padding: 2.5rem 1.5rem 4rem; }
  nav {
    display: flex; gap: 1.5rem; margin-bottom: 2.5rem;
    padding-bottom: 1rem; border-bottom: 1px solid #1e1e1e;
    font-size: 0.85rem;
  }
  nav a { color: #888; text-decoration: none; }
  nav a:hover { color: #ccc; }
  nav .logout { margin-left: auto; }

  h1 { font-size: 1.15rem; font-weight: 600; color: #ddd; margin-bottom: 1.5rem; }
  .empty { font-size: 0.9rem; color: #666; }

  .board { list-style: none; display: flex; flex-direction: column; }
  .board li {
    display: flex; align-items: center; gap: 0.9rem;
    padding: 0.75rem 0; border-top: 1px solid #1a1a1a;
  }
  .board li.me { background: #161616; margin: 0 -0.75rem; padding: 0.75rem; border-radius: 6px; border-top-color: transparent; }
  .rank { width: 1.5rem; text-align: right; font-variant-numeric: tabular-nums; color: #777; font-size: 0.9rem; }
  .avatar { width: 28px; height: 28px; border-radius: 50%; object-fit: cover; }
  .name { flex: 1; font-size: 0.95rem; color: #ddd; }
  .finds { font-size: 0.78rem; color: #777; }
  .points {
    font-variant-numeric: tabular-nums; font-weight: 600;
    font-size: 1rem; color: #6a9aba; min-width: 3rem; text-align: right;
  }
</style>
