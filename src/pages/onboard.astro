---
import '../styles/global.css';
import { getSession } from '../lib/auth';
import { db } from '../lib/db';

const session = getSession(Astro.cookies);
if (!session) return Astro.redirect('/');

const { rows: userRows } = await db.execute({
  sql: 'SELECT onboarding_status, review_note, about_text FROM users WHERE slack_id = ?',
  args: [session.slack_id],
});
const user = userRows[0];
const status = user?.onboarding_status as string;
const reviewNote = user?.review_note as string | null;
const aboutText = (user?.about_text as string | null) ?? '';

if (status === 'approved' || status === 'pending_review') {
  return Astro.redirect('/');
}

const { rows: fieldRows } = await db.execute(
  'SELECT id, prompt, difficulty, question_type, placeholder FROM clue_fields ORDER BY field_order, id'
);

const { rows: clueRows } = await db.execute({
  sql: 'SELECT field_id, answer FROM user_clues WHERE slack_id = ?',
  args: [session.slack_id],
});
const existingClues: Record<string, string> = Object.fromEntries(
  clueRows.map(r => [String(r.field_id), r.answer as string])
);
const { rows: customClues } = await db.execute({
  sql: "SELECT id, clue, difficulty FROM custom_clues WHERE slack_id = ? AND source = 'user' ORDER BY id",
  args: [session.slack_id],
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" />
    <title>pispy - gib us ur data :3</title>
  </head>
  <body class="bg-[#111] font-sans text-[#ccc]">
    <div class="mx-auto max-w-[480px] px-6 pt-12 pb-20">
      {reviewNote && (
        <div class="mb-8 border-l-2 border-[#555] bg-[#161616] px-4 py-3">
          <span class="text-[0.7rem] uppercase tracking-[0.1em] text-[#666]">changes requested</span>
          <p class="text-[0.9rem] text-[#bbb]">{reviewNote}</p>
        </div>
      )}

      <header class="mb-10 flex items-center gap-4">
        {session.avatar_url && <img src={session.avatar_url} alt="" class="h-12 w-12 rounded-full object-cover grayscale-[30%]" />}
        <span class="text-[1.1rem] text-[#ddd]">{session.display_name}</span>
      </header>
      <b>we thank you for trusting us with your data ; we will not extort, sell, or use this maliciously. the data shall only kept until the end of sunday/demos and usage scope limited to this project</b>
      <form id="onboard-form" action="/api/onboard" method="POST" enctype="multipart/form-data">
        <div class="mb-7">
          <label class="mb-[0.4rem] block text-[0.7rem] uppercase tracking-[0.12em] text-[#666]">badge photo</label>
          <p class="mb-3 text-[0.8rem] text-[#555]">a photo of your badge</p>
          <div id="badge-field">
            <div class="mb-[0.6rem] flex aspect-[4/3] w-full items-center justify-center overflow-hidden border border-[#222] bg-[#161616]">
              <img id="badge-preview" class="h-full w-full object-cover" hidden alt="" />
              <video id="badge-video" class="h-full w-full object-cover" autoplay playsinline muted hidden></video>
              <canvas id="badge-canvas" hidden></canvas>
            </div>
            <div class="flex flex-wrap items-center gap-[0.6rem]">
              <label class="cursor-pointer border border-[#333] bg-none px-[0.8rem] py-[0.35rem] font-sans text-[0.8rem] text-[#888] transition-colors hover:border-[#555] hover:text-[#ccc]">
                upload file(... sane img)
                <input type="file" id="badge-file" accept="image/*" hidden>
              </label>
              <span class="text-[0.75rem] text-[#444]">or</span>
              <button type="button" class="cursor-pointer border border-[#333] bg-none px-[0.8rem] py-[0.35rem] font-sans text-[0.8rem] text-[#888] transition-colors hover:border-[#555] hover:text-[#ccc]" id="badge-camera-open">use device camera</button>
              <button type="button" class="cursor-pointer border border-[#333] bg-none px-[0.8rem] py-[0.35rem] font-sans text-[0.8rem] text-[#888] transition-colors hover:border-[#555] hover:text-[#ccc]" id="badge-snap" hidden>snap(smilee)</button>
              <button type="button" class="cursor-pointer border-none bg-none py-[0.35rem] font-sans text-[0.8rem] text-[#555] hover:text-[#888]" id="badge-retake" hidden>retake</button>
            </div>
            <input type="hidden" name="badge_photo_data" id="badge-data" />
            <input type="file" name="badge_photo_file" id="badge-file-fallback" accept="image/*" class="hidden" />
          </div>
        </div>

        <div class="mb-7">
          <label class="mb-[0.4rem] block text-[0.7rem] uppercase tracking-[0.12em] text-[#666]">face photo(smile! :3)</label>
          <p class="mb-3 text-[0.8rem] text-[#555]">a clear photo of your face</p>
          <div id="face-field">
            <div class="mb-[0.6rem] flex aspect-[4/3] w-full items-center justify-center overflow-hidden border border-[#222] bg-[#161616]">
              <img id="face-preview" class="h-full w-full object-cover" hidden alt="" />
              <video id="face-video" class="h-full w-full object-cover" autoplay playsinline muted hidden></video>
              <canvas id="face-canvas" hidden></canvas>
            </div>
            <div class="flex flex-wrap items-center gap-[0.6rem]">
              <label class="cursor-pointer border border-[#333] bg-none px-[0.8rem] py-[0.35rem] font-sans text-[0.8rem] text-[#888] transition-colors hover:border-[#555] hover:text-[#ccc]">
                upload file
                <input type="file" id="face-file" accept="image/*" hidden>
              </label>
              <span class="text-[0.75rem] text-[#444]">or</span>
              <button type="button" class="cursor-pointer border border-[#333] bg-none px-[0.8rem] py-[0.35rem] font-sans text-[0.8rem] text-[#888] transition-colors hover:border-[#555] hover:text-[#ccc]" id="face-camera-open">use camera</button>
              <button type="button" class="cursor-pointer border border-[#333] bg-none px-[0.8rem] py-[0.35rem] font-sans text-[0.8rem] text-[#888] transition-colors hover:border-[#555] hover:text-[#ccc]" id="face-snap" hidden>snap</button>
              <button type="button" class="cursor-pointer border-none bg-none py-[0.35rem] font-sans text-[0.8rem] text-[#555] hover:text-[#888]" id="face-retake" hidden>retake</button>
            </div>
            <input type="hidden" name="face_photo_data" id="face-data" />
            <input type="file" name="face_photo_file" id="face-file-fallback" accept="image/*" class="hidden" />
          </div>
        </div>

        {fieldRows.length > 0 && (
          <div class="mb-7">
            <p class="mb-5 border-t border-[#1e1e1e] pt-2 text-[0.7rem] uppercase tracking-[0.12em] text-[#444]">clues</p>
            {fieldRows.map(field => (
              <div class="mb-7">
                <label for={`field-${field.id}`} class="mb-[0.4rem] block text-[0.7rem] uppercase tracking-[0.12em] text-[#666]">{field.prompt as string}</label>
                {field.question_type === 'yes_no' ? (
                  <div data-yes-no>
                    <div class="relative mb-[0.65rem] grid w-full grid-cols-2 overflow-hidden rounded-full border border-[#303030] bg-[#161616] p-[3px] focus-within:border-[#555] before:absolute before:top-[3px] before:left-[3px] before:z-0 before:h-[calc(100%-6px)] before:w-[calc(50%-3px)] before:rounded-full before:opacity-0 before:transition-all before:duration-[180ms] before:content-[''] has-[.choice-no_input:checked]:before:translate-x-0 has-[.choice-no_input:checked]:before:bg-[#713535] has-[.choice-no_input:checked]:before:opacity-100 has-[.choice-yes_input:checked]:before:translate-x-full has-[.choice-yes_input:checked]:before:bg-[#356b48] has-[.choice-yes_input:checked]:before:opacity-100">
                      <label class="choice-no relative z-[1] cursor-pointer select-none px-4 py-[0.45rem] text-center text-[0.82rem] uppercase tracking-[0.08em] text-[#777] transition-colors has-[input:checked]:text-white"><input type="radio" name={`clue_choice_${field.id}`} value="no" checked={existingClues[String(field.id)] === 'No'} class="absolute h-px w-px opacity-0" /><span>no</span></label>
                      <label class="choice-yes relative z-[1] cursor-pointer select-none px-4 py-[0.45rem] text-center text-[0.82rem] uppercase tracking-[0.08em] text-[#777] transition-colors has-[input:checked]:text-white"><input type="radio" name={`clue_choice_${field.id}`} value="yes" checked={(existingClues[String(field.id)] ?? '').startsWith('Yes')} class="absolute h-px w-px opacity-0" /><span>yes</span></label>
                    </div>
                    <input type="text" name={`clue_elaboration_${field.id}`} value={(existingClues[String(field.id)] ?? '').replace(/^Yes\s*[—-]?\s*/, '')} placeholder={field.placeholder as string} data-elaboration class="w-full border border-[#2a2a2a] bg-[#161616] px-[0.65rem] py-2 font-sans text-[0.9rem] text-[#ccc] outline-none transition-colors focus:border-[#555]" />
                  </div>
                ) : (
                  <input type="text" id={`field-${field.id}`} name={`clue_${field.id}`} value={existingClues[String(field.id)] ?? ''} placeholder={field.placeholder as string} autocomplete="off" class="w-full border border-[#2a2a2a] bg-[#161616] px-[0.65rem] py-2 font-sans text-[0.9rem] text-[#ccc] outline-none transition-colors focus:border-[#555]" />
                )}
              </div>
            ))}
          </div>
        )}

        <div class="mb-7 mt-10">
          <label for="about_text" class="mb-[0.4rem] block text-[0.7rem] uppercase tracking-[0.12em] text-[#666]">about you</label>
          <p class="mb-3 text-[0.8rem] leading-[1.5] text-[#555]">Write anything that'd help a hunter spot and find you at the event — what you look like, where you hang out, your hobbies, quirks, vibe. We'll turn it into clues (an admin reviews them before they go live).</p>
          <textarea id="about_text" name="about_text" rows="5" placeholder="e.g. I'm tall with curly hair and usually wear a green hoodie. You'll find me near the hardware tables or wherever there's coffee. I talk way too much about mechanical keyboards." class="w-full resize-y border border-[#2a2a2a] bg-[#161616] px-[0.65rem] py-2 font-sans text-[0.9rem] leading-[1.5] text-[#ccc] outline-none transition-colors focus:border-[#555]">{aboutText}</textarea>
        </div>

        <div class="mb-7 border border-[#262626] bg-[#141414] p-5 max-[420px]:p-4">
          <p class="mb-2 text-[0.7rem] uppercase tracking-[0.12em] text-[#888]">your own clues <span class="float-right normal-case tracking-normal text-[#555]">optional</span></p>
          <p class="mb-[1.1rem] text-[0.8rem] leading-[1.5] text-[#555]">Write your own clue!! Easy means that easy to link to you(generic/common attribute), hard means uniqueness</p>
          <div id="custom-clues" class="[counter-reset:custom-clue]">
            {customClues.map((clue, index) => (
              <div class="custom-clue-row mb-[0.65rem] grid grid-cols-[28px_1fr_28px] items-center gap-[0.65rem] border border-[#292929] bg-[#181818] p-3 transition-colors [counter-increment:custom-clue] focus-within:border-[#444] focus-within:bg-[#1a1a1a] max-[420px]:grid-cols-[1fr_28px]">
                <span class="grid h-7 w-7 place-items-center rounded-full border border-[#303030] font-mono text-[0.68rem] text-[#666] before:[content:counter(custom-clue,decimal-leading-zero)] max-[420px]:hidden" aria-hidden="true"></span>
                <div class="grid grid-cols-[minmax(0,1fr)_90px] gap-2 max-[420px]:grid-cols-[1fr]">
                  <input type="text" name={`custom_clue_${index}`} value={clue.clue as string} placeholder="e.g. I always carry a red water bottle" aria-label="custom clue" class="w-full border border-[#2a2a2a] bg-[#121212] px-[0.65rem] py-2 font-sans text-[0.9rem] text-[#ccc] outline-none transition-colors focus:border-[#555]" />
                  <select name={`custom_difficulty_${index}`} aria-label="clue difficulty" class="w-full cursor-pointer border border-[#2a2a2a] bg-[#121212] p-2 capitalize text-[#aaa]">
                    {['hard', 'medium', 'easy'].map(level => <option value={level} selected={clue.difficulty === level}>{level}</option>)}
                  </select>
                </div>
                <button type="button" class="remove-clue h-7 w-7 cursor-pointer border-0 bg-transparent text-[1.2rem] leading-none text-[#633] transition-colors hover:bg-[#241818] hover:text-[#c77]" aria-label="remove clue">×</button>
              </div>
            ))}
          </div>
          <template id="custom-clue-template">
            <div class="custom-clue-row mb-[0.65rem] grid grid-cols-[28px_1fr_28px] items-center gap-[0.65rem] border border-[#292929] bg-[#181818] p-3 transition-colors [counter-increment:custom-clue] focus-within:border-[#444] focus-within:bg-[#1a1a1a] max-[420px]:grid-cols-[1fr_28px]">
              <span class="grid h-7 w-7 place-items-center rounded-full border border-[#303030] font-mono text-[0.68rem] text-[#666] before:[content:counter(custom-clue,decimal-leading-zero)] max-[420px]:hidden" aria-hidden="true"></span>
              <div class="grid grid-cols-[minmax(0,1fr)_90px] gap-2 max-[420px]:grid-cols-[1fr]">
                <input type="text" placeholder="e.g. I always carry a red water bottle" aria-label="custom clue" class="w-full border border-[#2a2a2a] bg-[#121212] px-[0.65rem] py-2 font-sans text-[0.9rem] text-[#ccc] outline-none transition-colors focus:border-[#555]" />
                <select aria-label="clue difficulty" class="w-full cursor-pointer border border-[#2a2a2a] bg-[#121212] p-2 capitalize text-[#aaa]">
                  <option value="hard">hard</option>
                  <option value="medium" selected>medium</option>
                  <option value="easy">easy</option>
                </select>
              </div>
              <button type="button" class="h-7 w-7 cursor-pointer border-0 bg-transparent text-[1.2rem] leading-none text-[#633] transition-colors hover:bg-[#241818] hover:text-[#c77]" aria-label="remove clue">×</button>
            </div>
          </template>
          <button type="button" id="add-custom-clue" class="w-full cursor-pointer border border-dashed border-[#353535] bg-[#171717] px-4 py-[0.7rem] font-sans text-[0.82rem] text-[#777] transition-colors hover:border-[#555] hover:bg-[#1b1b1b] hover:text-[#bbb]"><span class="mr-[0.35rem] text-base text-[#999]">+</span> add another clue</button>
        </div>

        <div class="mt-10">
          <button type="submit" class="cursor-pointer border border-[#444] bg-none px-8 py-[0.6rem] font-sans text-[0.9rem] text-[#ccc] transition-colors hover:border-[#888] hover:text-white">submit for review</button>
        </div>
      </form>
    </div>

    <script>
      function setupPhotoField(id: string) {
        const fileInput = document.getElementById(`${id}-file`) as HTMLInputElement;
        const fileFallback = document.getElementById(`${id}-file-fallback`) as HTMLInputElement;
        const dataInput = document.getElementById(`${id}-data`) as HTMLInputElement;
        const preview = document.getElementById(`${id}-preview`) as HTMLImageElement;
        const video = document.getElementById(`${id}-video`) as HTMLVideoElement;
        const canvas = document.getElementById(`${id}-canvas`) as HTMLCanvasElement;
        const cameraOpen = document.getElementById(`${id}-camera-open`) as HTMLButtonElement;
        const snapBtn = document.getElementById(`${id}-snap`) as HTMLButtonElement;
        const retakeBtn = document.getElementById(`${id}-retake`) as HTMLButtonElement;

        let stream: MediaStream | null = null;

        function showPreview(dataUrl: string) {
          preview.src = dataUrl;
          preview.hidden = false;
          video.hidden = true;
          snapBtn.hidden = true;
          retakeBtn.hidden = false;
          cameraOpen.hidden = true;
          // hide fallback file input when JS-captured
          fileFallback.disabled = true;
        }

        fileInput.addEventListener('change', () => {
          const file = fileInput.files?.[0];
          if (!file) return;
          const reader = new FileReader();
          reader.onload = e => {
            const result = e.target?.result as string;
            dataInput.value = result;
            fileFallback.disabled = true;
            showPreview(result);
            stopStream();
          };
          reader.readAsDataURL(file);
        });

        cameraOpen.addEventListener('click', async () => {
          try {
            stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' } });
            video.srcObject = stream;
            video.hidden = false;
            preview.hidden = true;
            snapBtn.hidden = false;
            cameraOpen.hidden = true;
          } catch {
            alert('Could not access camera. Please upload a file instead.');
          }
        });

        snapBtn.addEventListener('click', () => {
          canvas.width = video.videoWidth;
          canvas.height = video.videoHeight;
          canvas.getContext('2d')!.drawImage(video, 0, 0);
          const dataUrl = canvas.toDataURL('image/jpeg', 0.85);
          dataInput.value = dataUrl;
          fileFallback.disabled = true;
          showPreview(dataUrl);
          stopStream();
        });

        retakeBtn.addEventListener('click', () => {
          dataInput.value = '';
          preview.hidden = true;
          retakeBtn.hidden = true;
          cameraOpen.hidden = false;
          fileFallback.disabled = false;
        });

        function stopStream() {
          stream?.getTracks().forEach(t => t.stop());
          stream = null;
          video.hidden = true;
        }
      }

      setupPhotoField('badge');
      setupPhotoField('face');

      function syncYesNo() {
        document.querySelectorAll<HTMLElement>('[data-yes-no]').forEach(group => {
          const yes = group.querySelector<HTMLInputElement>('input[value="yes"]');
          const elaboration = group.querySelector<HTMLInputElement>('[data-elaboration]');
          if (!yes || !elaboration) return;
          elaboration.hidden = !yes.checked;
          elaboration.required = yes.checked;
        });
      }
      document.querySelectorAll('[data-yes-no] input[type="radio"]').forEach(input => input.addEventListener('change', syncYesNo));
      syncYesNo();

      const customContainer = document.getElementById('custom-clues')!;
      const addCustom = document.getElementById('add-custom-clue')!;
      const customTemplate = document.getElementById('custom-clue-template') as HTMLTemplateElement;
      let customIndex = customContainer.children.length;
      function wireRemove(button: Element) {
        button.addEventListener('click', () => button.closest('.custom-clue-row')?.remove());
      }
      document.querySelectorAll('.remove-clue').forEach(wireRemove);
      addCustom.addEventListener('click', () => {
        const row = customTemplate.content.firstElementChild!.cloneNode(true) as HTMLElement;
        const clueInput = row.querySelector<HTMLInputElement>('input[type="text"]')!;
        const difficultySelect = row.querySelector<HTMLSelectElement>('select')!;
        clueInput.name = `custom_clue_${customIndex}`;
        difficultySelect.name = `custom_difficulty_${customIndex}`;
        customIndex += 1;
        customContainer.appendChild(row);
        wireRemove(row.querySelector('.remove-clue')!);
        clueInput.focus();
      });

      // hide fallback file inputs (they're JS-only fallback for no-JS)
      document.querySelectorAll('.fallback-file').forEach(el => {
        (el as HTMLElement).style.display = 'none';
      });
    </script>
  </body>
</html>
