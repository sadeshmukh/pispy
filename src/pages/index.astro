---
import { getSession } from '../lib/auth';
import { db } from '../lib/db';

const session = getSession(Astro.cookies);

let status: string | null = null;
if (session) {
  const { rows } = await db.execute({
    sql: 'SELECT onboarding_status FROM users WHERE slack_id = ?',
    args: [session.slack_id],
  });
  status = rows[0]?.onboarding_status as string ?? null;

  if (status === 'pending_submission' || status === 'changes_requested') {
    return Astro.redirect('/onboard');
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" />
    <title>pispy</title>
  </head>
  <body>
    <main>
      {!session ? (
        <a href="/api/auth/login">Sign in</a>
      ) : status === 'pending_review' ? (
        <div class="status-block">
          <p>Your account is pending review.(no fraudsters)</p>
          <a href="/api/auth/logout">Log out</a>
        </div>
      ) : (
        <div class="status-block">
          <p>{session.display_name}</p>
          <a href="/hunt">Hunt</a>
          <a href="/leaderboard">Leaderboard</a>
          <a href="/api/auth/logout">Log out</a>
        </div>
      )}
    </main>
  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { width: 100%; height: 100%; background: #111; }
  main {
    width: 100%; height: 100vh;
    display: flex; align-items: center; justify-content: center;
  }
  a, p {
    color: #ccc;
    font-family: system-ui, -apple-system, sans-serif;
    font-size: 1rem;
    text-decoration: none;
  }
  a:hover { color: #fff; }
  .status-block {
    display: flex; flex-direction: column;
    align-items: center; gap: 1.2rem;
  }
</style>
