---
import '../styles/global.css';
import { getSession } from '../lib/auth';
import { db } from '../lib/db';

const session = getSession(Astro.cookies);

let status: string | null = null;
if (session) {
  const { rows } = await db.execute({
    sql: 'SELECT onboarding_status FROM users WHERE slack_id = ?',
    args: [session.slack_id],
  });
  status = rows[0]?.onboarding_status as string ?? null;

  if (status === 'pending_submission' || status === 'changes_requested') {
    return Astro.redirect('/onboard');
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" />
    <title>pispy</title>
  </head>
  <body>
    <main class="grid min-h-screen place-items-center px-6 py-10">
      <section class="w-full max-w-md rounded-lg border-2 border-slate-900 bg-white p-8 shadow-[10px_10px_0_#ffd166]">
        <div class="mb-4 flex items-center gap-3 text-xs font-black uppercase tracking-wide text-slate-500">
          <span class="h-3 w-3 rounded-full bg-rose-500 shadow-[18px_0_0_#38bdf8,36px_0_0_#ffd166]"></span>
          pispy
        </div>

      {!session ? (
        <>
          <h1 class="m-0 text-5xl font-black leading-none text-slate-900 sm:text-6xl">Find your people.</h1>
          <p class="my-5 text-base leading-7 text-slate-600">
            Join the campus photo clue game and get set up in a couple quick steps.
          </p>
          <a href="/api/auth/login" class="inline-flex min-h-11 items-center justify-center rounded-md border-2 border-slate-900 bg-yellow-300 px-5 py-3 text-sm font-black text-slate-900 no-underline shadow-[4px_4px_0_rgba(15,23,42,0.2)] transition hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-[6px_6px_0_rgba(15,23,42,0.22)]">
            Join with Slack
          </a>
        </>
      ) : status === 'pending_review' ? (
        <div>
          <h1 class="m-0 text-4xl font-black leading-none text-slate-900">You're in the queue.</h1>
          <p class="my-5 text-base leading-7 text-slate-600">Your submission is waiting for review.</p>
          <a href="/api/auth/logout" class="inline-flex min-h-10 items-center justify-center rounded-md border-2 border-slate-300 bg-white px-4 py-2 text-sm font-black text-slate-700 no-underline shadow-[3px_3px_0_rgba(15,23,42,0.12)] transition hover:-translate-x-0.5 hover:-translate-y-0.5">
            Log out
          </a>
        </div>
      ) : (
        <div>
          <h1 class="m-0 text-4xl font-black leading-none text-slate-900">Hi, {session.display_name}.</h1>
          <p class="my-5 text-base leading-7 text-slate-600">Your profile is ready.</p>
          <a href="/api/auth/logout" class="inline-flex min-h-10 items-center justify-center rounded-md border-2 border-slate-300 bg-white px-4 py-2 text-sm font-black text-slate-700 no-underline shadow-[3px_3px_0_rgba(15,23,42,0.12)] transition hover:-translate-x-0.5 hover:-translate-y-0.5">
            Log out
          </a>
        </div>
      )}
      </section>
    </main>
  </body>
</html>
